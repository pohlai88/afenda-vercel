{
  // Type-checks tests/ in isolation so Playwright + Vitest types stay out of the
  // main compile graph. Run with: pnpm typecheck:test
  // See docs/testing/typescript-compile-efficiency.md
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "tsBuildInfoFile": "../.artifacts/.tsbuildinfo/test",
    "assumeChangesOnlyAffectDirectDependencies": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "plugins": []
  },
  "include": [
    "../next-env.d.ts",
    "../i18n/global.d.ts",
    "../tests/**/*.ts",
    "../tests/**/*.tsx",
    "vitest.config.ts",
    "vitest.shared.ts",
    "vitest.setup.shared.ts",
    "vitest.setup.dom.ts",
    "playwright.config.ts"
  ],
  "exclude": [
    "../node_modules",
    "../.next",
    "../.next-ui",
    "../.next-workflow"
  ]
}
