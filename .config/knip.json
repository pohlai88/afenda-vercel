{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "next": true,
  "vitest": {
    "config": [".config/vitest.config.ts"]
  },
  "playwright": {
    "config": [".config/playwright.config.ts"]
  },
  "drizzle": {
    "config": [".config/drizzle.config.ts"]
  },
  "treatConfigHintsAsErrors": false,
  "ignoreExportsUsedInFile": true,
  "entry": [
    "package.json",
    "scripts/**/*.{mjs,cjs,js,ts}",
    "tests/**/*.{ts,tsx}",
    ".config/**/*.{ts,mjs}",
    "turbo/generators/**/*.{ts,mjs,cjs,js}"
  ],
  "rules": {
    "files": "error",
    "dependencies": "error",
    "devDependencies": "error",
    "unlisted": "error",
    "unresolved": "error",
    "binaries": "error",
    "catalog": "error",
    "exports": "error",
    "types": "error",
    "enumMembers": "warn",
    "namespaceMembers": "warn",
    "nsExports": "warn",
    "nsTypes": "warn",
    "duplicates": "warn"
  },
  "ignoreFiles": [
    "components2/ui/**",
    ".source/**",
    "lib/features/bootstrap/index.ts",
    "lib/features/iam-profile/index.ts",
    "lib/features/tools/client.ts",
    "components2/app-shell/surface/appshell-sub-layout.tsx",
    "lib/features/hrm/employee-management/documents-management/{index,client}.ts",
    "lib/features/hrm/employee-management/employee-lifecycle-management/{client,actions/employment-status-change.actions,schemas/employment-status-change.schema}.ts",
    "lib/features/hrm/employee-management/employee-records-management/{actions/emergency-contact.actions,components/employee-edit-form,schemas/emergency-contact.schema}.{ts,tsx}",
    "lib/features/hrm/employee-management/employee-selfservice-portal/{client,actions/employee-portal-acknowledgement.actions}.ts",
    "lib/features/hrm/employee-management/offboarding-exit-management/data/offboarding-exit-summary.queries.server.ts",
    "lib/features/hrm/payroll-compensation/benefits-administration/{index,server}.ts",
    "lib/features/hrm/payroll-compensation/expenses-reimbursement/{client,index,server}.ts",
    "lib/features/hrm/payroll-compensation/expenses-reimbursement/{actions/claim-duplicate.actions,actions/claim-payment.actions,data/claim-duplicate.queries.server}.ts",
    "lib/features/hrm/payroll-compensation/multi-country-payroll/{client,index,multi-country-payroll-form-states}.ts",
    "lib/features/hrm/payroll-compensation/multi-country-payroll/{actions/multi-country-payroll.actions,schemas/vn-payroll-line-code.shared}.ts",
    "lib/features/hrm/payroll-compensation/payroll-processing/payroll-form-states.ts",
    "lib/features/hrm/payroll-compensation/payroll-processing/{actions,data,schemas}/*.{ts,tsx}",
    "lib/features/hrm/payroll-compensation/salary-benchmarking-survey/{client,actions/salary-benchmarking.actions,data/salary-benchmarking.mutations.server,schemas/salary-benchmarking-action.schema}.ts",
    "lib/features/hrm/talent-management/candidate-selfservice-portal/{client,index}.ts",
    "lib/features/hrm/time-attendance/leave-attendance-management/components/{employee-portal-leave-cancel-button,employee-portal-leave-page,employee-portal-leave-request-form,leave-recent-table}.tsx",
    "lib/features/execution/data/org-domain-signal-run-entry.ts",
    "lib/features/execution/data/org-domain-signal.{mutations.server,workflow}.ts",
    "lib/features/execution/schemas/org-domain-signal-payload.schema.ts",
    "lib/features/governed-surface/data/list-surface-trailing-action.server.ts",
    "lib/features/governed-surface/schemas/{governed-registry,server-actions}.shared.ts",
    "lib/features/lynx/data/federated-search.queries.server.ts"
  ],
  "ignoreDependencies": [
    "@better-auth/infra",
    "@better-auth/passkey",
    "better-auth",
    "markdownlint-cli2",
    "@base-ui/react",
    "@hookform/resolvers",
    "date-fns",
    "embla-carousel-react",
    "react-day-picker",
    "react-hook-form",
    "react-resizable-panels",
    "vaul",
    "@radix-ui/react-use-controllable-state",
    "@rive-app/react-webgl2",
    "@streamdown/cjk",
    "@streamdown/code",
    "@streamdown/math",
    "@streamdown/mermaid",
    "@vercel/sandbox",
    "@xyflow/react",
    "ansi-to-react",
    "media-chrome",
    "motion",
    "nanoid",
    "next-devtools-mcp",
    "pino-pretty",
    "react-jsx-parser",
    "shiki",
    "streamdown",
    "tokenlens",
    "use-stick-to-bottom",
    "turbo"
  ],
  "ignoreIssues": {
    "lib/auth/index.ts": [
      "exports",
      "types",
      "enumMembers",
      "namespaceMembers",
      "nsExports",
      "nsTypes"
    ],
    "lib/auth-client.ts": ["exports", "types"],
    "lib/db/schema-neon-auth.ts": ["exports", "types"],
    "lib/design-system.ts": [
      "exports",
      "types",
      "enumMembers",
      "namespaceMembers",
      "nsExports",
      "nsTypes"
    ],
    "lib/features/*/index.ts": [
      "exports",
      "types",
      "enumMembers",
      "namespaceMembers",
      "nsExports",
      "nsTypes"
    ],
    "lib/features/*/server.ts": [
      "files",
      "exports",
      "types",
      "enumMembers",
      "namespaceMembers",
      "nsExports",
      "nsTypes"
    ],
    "lib/features/*/client.ts": [
      "exports",
      "types",
      "enumMembers",
      "namespaceMembers",
      "nsExports",
      "nsTypes"
    ],
    "lib/features/**/constants.ts": ["exports", "types"],
    "lib/**/*.shared.ts": [
      "exports",
      "types",
      "enumMembers",
      "namespaceMembers"
    ],
    "lib/auth/**/*.server.ts": ["exports", "types"],
    "lib/auth/org-audit.server.ts": ["exports", "types"],
    "lib/dashboard-module-paths.ts": ["exports", "types"],
    "lib/org-apps-module-paths.ts": ["exports", "types"],
    "lib/i18n/dashboard-org-path.shared.ts": ["exports", "types"],
    "lib/portal/constants.ts": ["exports", "types"],
    "lib/features/operational-scope/types.ts": ["exports", "types"],
    "lib/features/hrm/types.ts": ["exports", "types"],
    "lib/features/hrm/payroll-compensation/benefits-administration/schemas/*.schema.ts": [
      "exports",
      "types"
    ],
    "lib/features/hrm/payroll-compensation/bonus-incentive-management/schemas/*.schema.ts": [
      "exports",
      "types"
    ],
    "lib/features/hrm/payroll-compensation/expenses-reimbursement/schemas/*.schema.ts": [
      "exports",
      "types"
    ],
    "components2/feedback/client.tsx": ["exports", "types"],
    "components2/iam-profile/iam-profile-security-context.client.tsx": [
      "exports",
      "types"
    ],
    "components2/legal-docs/legal-docs-status-pill.shared.tsx": [
      "exports",
      "types"
    ],
    "components2/marketing/marketing-afenda-brand.client.tsx": [
      "exports",
      "types"
    ],
    "components2/marketing/marketing-public-href.shared.tsx": [
      "exports",
      "types"
    ],
    "lib/site.ts": ["exports", "types", "duplicates"],
    "components2/ui/**/*.tsx": [
      "exports",
      "types",
      "enumMembers",
      "namespaceMembers",
      "nsExports",
      "nsTypes"
    ],
    "components2/ui/**/*.ts": ["exports", "types"],
    "components2/afenda-brand.tsx": ["exports", "types"],
    "components2/auth/**/*.tsx": ["exports", "types"],
    "components2/nexus/**/*.tsx": ["exports", "types"],
    "components2/nexus/**/*.ts": ["exports", "types"],
    "components2/app-shell/**/*.tsx": ["exports", "types"],
    "components2/app-shell/**/*.ts": ["exports", "types"],
    "components2/erp-surface-coming-soon.tsx": ["exports", "types"],
    "components2/route-loading/**/*.tsx": ["exports", "types"],
    "components2/route-error/**/*.tsx": ["exports", "types"],
    "i18n/navigation.tsx": ["exports", "types"],
    "tests/fixtures/**/*.ts": ["exports", "types"],
    "tests/unit/nexus-lynx-grounded-truth-question.test.ts": ["files"],
    "lib/features/**/data/*.ts": ["exports", "types"],
    "lib/features/**/actions/*.ts": ["exports", "types"],
    "lib/features/**/schemas/*.ts": ["exports", "types"],
    "lib/features/**/components/*.tsx": ["exports", "types"],
    "lib/features/**/*.contract.ts": ["exports", "types"],
    "lib/features/orbit/automation/**": ["files"],
    "lib/features/orbit/client/**": ["files"],
    "lib/features/orbit/integrations/**": ["files"],
    "lib/features/orbit/filters/**": ["files"],
    "lib/features/orbit/policies/**": ["files"],
    "lib/features/orbit/recurrence/**": ["files"],
    "lib/features/orbit/relations/**": ["files"],
    "lib/features/orbit/scheduling/**": ["files"],
    "lib/features/orbit/timeline/**": ["files"],
    "lib/features/orbit/signals/**": ["files"],
    "lib/features/rail-memory/client.ts": ["files"],
    "lib/features/rail-memory/data/recent.queries.server.ts": ["files"],
    "lib/features/rail-memory/data/recent.mutations.server.ts": ["files"]
  }
}
