{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "next": true,
  "vitest": {
    "config": [".config/vitest.config.ts"]
  },
  "playwright": {
    "config": [".config/playwright.config.ts"]
  },
  "drizzle": {
    "config": [".config/drizzle.config.ts"]
  },
  "treatConfigHintsAsErrors": false,
  "ignoreExportsUsedInFile": true,
  "entry": [
    "package.json",
    "scripts/**/*.{mjs,cjs,js,ts}",
    "tests/**/*.{ts,tsx}",
    ".config/**/*.{ts,mjs}",
    "turbo/generators/**/*.{ts,mjs,cjs,js}"
  ],
  "rules": {
    "files": "error",
    "dependencies": "error",
    "devDependencies": "error",
    "unlisted": "error",
    "unresolved": "error",
    "binaries": "error",
    "catalog": "error",
    "exports": "error",
    "types": "error",
    "enumMembers": "warn",
    "namespaceMembers": "warn",
    "nsExports": "warn",
    "nsTypes": "warn",
    "duplicates": "warn"
  },
  "ignoreFiles": ["components2/ui/**"],
  "ignoreDependencies": [
    "@better-auth/infra",
    "@better-auth/passkey",
    "better-auth",
    "@base-ui/react",
    "@hookform/resolvers",
    "date-fns",
    "embla-carousel-react",
    "react-day-picker",
    "react-hook-form",
    "react-resizable-panels",
    "vaul",
    "@radix-ui/react-use-controllable-state",
    "@rive-app/react-webgl2",
    "@streamdown/cjk",
    "@streamdown/code",
    "@streamdown/math",
    "@streamdown/mermaid",
    "@vercel/sandbox",
    "@xyflow/react",
    "ansi-to-react",
    "media-chrome",
    "motion",
    "nanoid",
    "next-devtools-mcp",
    "pino-pretty",
    "react-jsx-parser",
    "shiki",
    "streamdown",
    "tokenlens",
    "use-stick-to-bottom",
    "turbo"
  ],
  "ignoreIssues": {
    "lib/auth/index.ts": [
      "exports",
      "types",
      "enumMembers",
      "namespaceMembers",
      "nsExports",
      "nsTypes"
    ],
    "lib/auth-client.ts": ["exports", "types"],
    "lib/db/schema-neon-auth.ts": ["exports", "types"],
    "lib/design-system.ts": [
      "exports",
      "types",
      "enumMembers",
      "namespaceMembers",
      "nsExports",
      "nsTypes"
    ],
    "lib/features/*/index.ts": [
      "exports",
      "types",
      "enumMembers",
      "namespaceMembers",
      "nsExports",
      "nsTypes"
    ],
    "lib/features/*/server.ts": [
      "files",
      "exports",
      "types",
      "enumMembers",
      "namespaceMembers",
      "nsExports",
      "nsTypes"
    ],
    "lib/features/*/client.ts": [
      "exports",
      "types",
      "enumMembers",
      "namespaceMembers",
      "nsExports",
      "nsTypes"
    ],
    "lib/features/**/constants.ts": ["exports", "types"],
    "lib/**/*.shared.ts": [
      "exports",
      "types",
      "enumMembers",
      "namespaceMembers"
    ],
    "lib/auth/**/*.server.ts": ["exports", "types"],
    "lib/auth/org-audit.server.ts": ["exports", "types"],
    "lib/dashboard-module-paths.ts": ["exports", "types"],
    "lib/i18n/dashboard-org-path.shared.ts": ["exports", "types"],
    "lib/site.ts": ["exports", "types", "duplicates"],
    "components2/ui/**/*.tsx": [
      "exports",
      "types",
      "enumMembers",
      "namespaceMembers",
      "nsExports",
      "nsTypes"
    ],
    "components2/ui/**/*.ts": ["exports", "types"],
    "components2/afenda-brand.tsx": ["exports", "types"],
    "components2/auth/**/*.tsx": ["exports", "types"],
    "components2/nexus/**/*.tsx": ["exports", "types"],
    "components2/nexus/**/*.ts": ["exports", "types"],
    "components2/app-shell/**/*.tsx": ["exports", "types"],
    "components2/app-shell/**/*.ts": ["exports", "types"],
    "components2/erp-surface-coming-soon.tsx": ["exports", "types"],
    "components2/route-loading/**/*.tsx": ["exports", "types"],
    "components2/route-error/**/*.tsx": ["exports", "types"],
    "i18n/navigation.tsx": ["exports", "types"],
    "tests/fixtures/**/*.ts": ["exports", "types"],
    "tests/unit/nexus-lynx-grounded-truth-question.test.ts": ["files"],
    "lib/features/**/data/*.ts": ["exports", "types"],
    "lib/features/**/actions/*.ts": ["exports", "types"],
    "lib/features/**/schemas/*.ts": ["exports", "types"],
    "lib/features/**/components/*.tsx": ["exports", "types"],
    "lib/features/**/*.contract.ts": ["exports", "types"],
    "lib/features/planner/automation/**": ["files"],
    "lib/features/planner/client/**": ["files"],
    "lib/features/planner/integrations/**": ["files"],
    "lib/features/planner/filters/**": ["files"],
    "lib/features/planner/policies/**": ["files"],
    "lib/features/planner/recurrence/**": ["files"],
    "lib/features/planner/relations/**": ["files"],
    "lib/features/planner/scheduling/**": ["files"],
    "lib/features/planner/timeline/**": ["files"],
    "lib/features/planner/signals/**": ["files"],
    "lib/features/rail-memory/client.ts": ["files"],
    "lib/features/rail-memory/data/recent.queries.server.ts": ["files"],
    "lib/features/rail-memory/data/recent.mutations.server.ts": ["files"]
  }
}
