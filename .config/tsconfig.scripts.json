{
  // Type-checks scripts/ in isolation so seed/AI-gateway scripts and their deps
  // stay out of the main compile graph. Run with: pnpm typecheck:scripts
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "tsBuildInfoFile": "../.artifacts/.tsbuildinfo/scripts",
    "assumeChangesOnlyAffectDirectDependencies": true,
    "noEmit": true,
    "plugins": []
  },
  "include": ["../scripts/**/*.ts", "drizzle.config.ts", "source.config.ts"],
  "exclude": ["../node_modules"]
}
