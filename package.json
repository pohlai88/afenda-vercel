{
  "name": "afenda-vercel",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.21.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "imports": {
    "#components/*": "./components/*.tsx",
    "#lib/*": "./lib/*",
    "#hooks/*": "./hooks/*.ts",
    "#features/*": "./lib/features/*"
  },
  "scripts": {
    "preinstall": "node scripts/check-agent-contract.mjs",
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "pnpm run lint:agent-contract && eslint . && pnpm run lint:design-contract",
    "lint:agent-contract": "node scripts/check-agent-contract.mjs",
    "lint:design-contract": "node scripts/check-design-contract.mjs",
    "format": "prettier --write \"**/*.{ts,tsx,mjs,css,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,mjs,css,json}\"",
    "typecheck": "tsc --noEmit",
    "smoke": "pnpm lint && pnpm typecheck && pnpm build",
    "env:sync": "node scripts/sync-env.mjs",
    "env:push-vercel": "node scripts/push-vercel-env.mjs",
    "env:pull-vercel": "vercel env pull .env.vercel",
    "shadcn:info": "shadcn info --json",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "auth:generate": "pnpm exec auth generate --config lib/auth/config.server.ts --output lib/db/schema.generated.ts -y",
    "icons:favicon": "node scripts/generate-favicon.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@better-auth/passkey": "^1.6.9",
    "@hookform/resolvers": "^5.2.2",
    "@neondatabase/serverless": "^1.1.0",
    "@vercel/blob": "^2.3.3",
    "@vercel/otel": "^2.1.2",
    "better-auth": "^1.6.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.14.0",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.75.0",
    "react-resizable-panels": "^4.11.0",
    "recharts": "3.8.0",
    "resend": "^6.12.2",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@next/env": "16.2.4",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "auth": "1.6.9",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.4",
    "pg": "^8.20.0",
    "postcss": "^8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "shadcn": "^4.7.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.1",
    "to-ico": "^1.1.5",
    "typescript": "^5.9.3",
    "vercel": "^48.6.0"
  }
}
