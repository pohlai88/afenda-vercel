{
  "name": "afenda-vercel",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.21.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "imports": {
    "#components/*": "./components/*.tsx",
    "#lib/*": "./lib/*",
    "#hooks/*": "./hooks/*.ts",
    "#features/*": "./lib/features/*",
    "#i18n/*": "./i18n/*"
  },
  "scripts": {
    "preinstall": "node scripts/check-agent-contract.mjs",
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "pnpm run lint:agent-contract && pnpm run lint:drizzle-journal && eslint . --max-warnings 0 --report-unused-disable-directives && pnpm run lint:design-contract",
    "lint:a11y": "eslint . -c eslint-a11y.config.mjs --report-unused-disable-directives --max-warnings 0",
    "lint:agent-contract": "node scripts/check-agent-contract.mjs",
    "lint:drizzle-journal": "node scripts/check-drizzle-journal.mjs",
    "lint:design-contract": "node scripts/check-design-contract.mjs",
    "format": "prettier --write \"**/*.{ts,tsx,mjs,css,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,mjs,css,json}\"",
    "typecheck": "tsc --noEmit",
    "typecheck:test": "tsc --noEmit -p tsconfig.test.json",
    "typecheck:scripts": "tsc --noEmit -p tsconfig.scripts.json",
    "test": "vitest",
    "test:coverage": "node scripts/with-env.mjs vitest run --coverage",
    "test:ci": "node scripts/with-env.mjs vitest run --coverage",
    "test:e2e": "pnpm build && node scripts/with-env.mjs playwright test",
    "test:e2e:smoke": "pnpm build && node scripts/with-env.mjs playwright test --grep @smoke",
    "test:e2e:ci": "pnpm build && node scripts/with-env.mjs playwright test",
    "verify": "pnpm lint && pnpm typecheck && pnpm typecheck:test && pnpm typecheck:scripts && pnpm knip && pnpm test:ci && pnpm format:check",
    "smoke": "pnpm lint && pnpm typecheck && pnpm build",
    "env:sync": "node scripts/sync-env.mjs",
    "verify:upstash": "node --env-file=.env.local scripts/verify-upstash-redis.mjs",
    "env:push-vercel": "node scripts/push-vercel-env.mjs",
    "env:pull-vercel": "vercel env pull .env.vercel",
    "neon-auth:configure": "node scripts/configure-neon-auth.mjs",
    "shadcn:info": "shadcn info --json",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:extensions:local": "node scripts/with-env.mjs node scripts/enable-pgvector.mjs",
    "db:migrate:local": "dotenv -e .env.local -- drizzle-kit migrate",
    "db:migrate:vercel": "dotenv -e .env.vercel -- drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:push:local": "dotenv -e .env.local -- drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:studio:local": "dotenv -e .env.local -- drizzle-kit studio",
    "icons:favicon": "node scripts/generate-favicon.mjs",
    "knip": "knip --no-progress",
    "knip:production": "knip --no-progress --production",
    "ai:gateway:smoke": "tsx scripts/ai-gateway-stream-text.ts",
    "ai:gateway:image": "tsx scripts/ai-gateway-generate-image.ts",
    "lynx:seed-demo": "node scripts/with-env.mjs tsx scripts/seed-lynx-demo.ts",
    "dev:seed": "node scripts/with-env.mjs node scripts/seed-dev-users.mjs",
    "openstatus:sync-ci": "node scripts/with-env.mjs node scripts/openstatus-sync-ci.mjs",
    "openstatus:env-hints": "node scripts/with-env.mjs node scripts/openstatus-env-hints.mjs",
    "openstatus:validate-feed": "node scripts/with-env.mjs node scripts/validate-openstatus-feed.mjs"
  },
  "dependencies": {
    "@ai-sdk/gateway": "^3.0.110",
    "@ai-sdk/openai": "^3.0.62",
    "@base-ui/react": "^1.4.1",
    "@better-auth/infra": "0.2.5",
    "@better-auth/passkey": "1.4.9",
    "@hookform/resolvers": "^5.2.2",
    "@neondatabase/auth": "0.3.0-beta",
    "@neondatabase/serverless": "^1.1.0",
    "@opentelemetry/api": "^1.9.1",
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@rive-app/react-webgl2": "^4.28.3",
    "@sentry/nextjs": "^10.52.0",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "@vercel/blob": "^2.3.3",
    "@vercel/otel": "^2.1.2",
    "@vercel/sandbox": "^1.10.0",
    "@xyflow/react": "^12.10.2",
    "ai": "^6.0.175",
    "ansi-to-react": "^6.2.6",
    "better-auth": "1.4.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.14.0",
    "media-chrome": "^4.19.0",
    "motion": "^12.38.0",
    "nanoid": "^5.1.11",
    "next": "16.2.4",
    "next-intl": "^4.11.0",
    "next-themes": "^0.4.6",
    "pino": "^10.3.1",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.75.0",
    "react-jsx-parser": "^2.4.1",
    "react-resizable-panels": "^4.11.0",
    "recharts": "3.8.0",
    "resend": "^6.12.2",
    "server-only": "^0.0.1",
    "shiki": "^4.0.2",
    "sonner": "^2.0.7",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.5.0",
    "tokenlens": "^1.3.1",
    "tw-animate-css": "^1.4.0",
    "use-stick-to-bottom": "^1.1.4",
    "vaul": "^1.1.2",
    "workflow": "^4.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@next/env": "16.2.4",
    "@openstatus/sdk-node": "^0.1.6",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "jsdom": "^29.1.1",
    "knip": "^6.12.0",
    "next-devtools-mcp": "0.3.10",
    "pg": "^8.20.0",
    "pino-pretty": "^13.1.3",
    "postcss": "^8",
    "postcss-load-config": "^6.0.1",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "shadcn": "^4.7.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.1",
    "to-ico": "^1.1.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vercel": "^48.6.0",
    "vitest": "^4.1.5"
  }
}
