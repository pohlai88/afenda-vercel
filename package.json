{
  "name": "afenda-vercel",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.21.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "imports": {
    "#components/*": "./components/*",
    "#components2/*": "./components2/*",
    "#app-shell": "./components2/app-shell/index.ts",
    "#lib/*": "./lib/*",
    "#hooks/*": "./hooks/*",
    "#features/*": "./lib/features/*",
    "#i18n/*": "./i18n/*",
    "#flags": "./flags.ts"
  },
  "scripts": {
    "preinstall": "node scripts/check-agent-contract.mjs",
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "gen": "node scripts/turbo-gen.mjs",
    "lint": "node scripts/turbo-with-env.mjs run lint:agent-contract lint:drizzle-journal lint:fixtures-parity lint:eslint lint:design-contract --output-logs=new-only",
    "lint:a11y": "eslint . -c .config/eslint-a11y.config.mjs --report-unused-disable-directives --max-warnings 0",
    "lint:agent-contract": "node scripts/check-agent-contract.mjs",
    "lint:drizzle-journal": "node scripts/check-drizzle-journal.mjs",
    "lint:fixtures-parity": "node scripts/with-env.mjs pnpm exec vitest run tests/unit/fixtures-i18n-parity.test.ts --config .config/vitest.config.ts",
    "lint:eslint": "eslint . --max-warnings 0 --report-unused-disable-directives --cache --cache-location .artifacts/.eslintcache",
    "lint:design-contract": "node scripts/check-design-contract.mjs",
    "format": "prettier --write --cache --cache-location .artifacts/.prettiercache \"**/*.{ts,tsx,mjs,css,json}\"",
    "format:check": "prettier --check --cache --cache-location .artifacts/.prettiercache \"**/*.{ts,tsx,mjs,css,json}\"",
    "typecheck": "tsc --noEmit",
    "typecheck:test": "tsc --noEmit -p .config/tsconfig.test.json",
    "typecheck:scripts": "tsc --noEmit -p .config/tsconfig.scripts.json",
    "test": "vitest --config .config/vitest.config.ts",
    "test:fast": "node scripts/with-env.mjs vitest run --config .config/vitest.config.ts",
    "test:coverage": "node scripts/with-env.mjs vitest run --config .config/vitest.config.ts --coverage",
    "test:analyze:imports": "node scripts/with-env.mjs vitest run --config .config/vitest.config.ts --experimental.importDurations.print=true --experimental.importDurations.limit=30",
    "test:analyze:imports:warn": "node scripts/with-env.mjs vitest run --config .config/vitest.config.ts --experimental.importDurations.print=on-warn --experimental.importDurations.limit=30",
    "test:ci": "node scripts/with-env.mjs vitest run --config .config/vitest.config.ts --coverage",
    "test:e2e": "pnpm build && node scripts/with-env.mjs playwright test --config .config/playwright.config.ts",
    "test:e2e:smoke": "pnpm build && node scripts/with-env.mjs playwright test --config .config/playwright.config.ts --grep @smoke",
    "test:e2e:ci": "pnpm build && node scripts/with-env.mjs playwright test --config .config/playwright.config.ts",
    "integrity:static": "concurrently -n lint,tc,tc:test,tc:scripts,knip,fmt -c auto \"pnpm lint\" \"pnpm typecheck\" \"pnpm typecheck:test\" \"pnpm typecheck:scripts\" \"pnpm knip\" \"pnpm format:check\"",
    "integrity:behavior": "pnpm test:fast",
    "verify": "node scripts/turbo-with-env.mjs run lint:agent-contract lint:drizzle-journal lint:fixtures-parity lint:eslint lint:design-contract typecheck typecheck:test typecheck:scripts knip test:ci format:check --output-logs=new-only",
    "verify:ci": "node scripts/turbo-with-env.mjs run lint:agent-contract lint:drizzle-journal lint:fixtures-parity lint:eslint lint:design-contract typecheck typecheck:test typecheck:scripts knip test:ci format:check --concurrency=8 --output-logs=errors-only",
    "verify:parallel": "node scripts/turbo-with-env.mjs run lint:agent-contract lint:drizzle-journal lint:fixtures-parity lint:eslint lint:design-contract typecheck typecheck:test typecheck:scripts knip test:ci format:check --output-logs=new-only",
    "verify:quick": "concurrently -n tc,tc:test,tc:scripts -c auto \"pnpm typecheck\" \"pnpm typecheck:test\" \"pnpm typecheck:scripts\" && pnpm integrity:behavior",
    "verify:artifact": "pnpm lint && pnpm typecheck && pnpm build",
    "smoke": "pnpm verify:artifact",
    "prepare": "husky",
    "env:sync": "node scripts/sync-env.mjs",
    "validate:legal-declarations": "node scripts/with-env.mjs tsx scripts/validate-legal-declarations.ts",
    "verify:upstash": "node --env-file=.env.local scripts/verify-upstash-redis.mjs",
    "env:push-vercel": "node scripts/push-vercel-env.mjs",
    "env:pull-vercel": "vercel env pull .env.vercel",
    "neon-auth:configure": "node scripts/configure-neon-auth.mjs",
    "shadcn:info": "shadcn info --json",
    "db:generate": "drizzle-kit generate --config .config/drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config .config/drizzle.config.ts && pnpm run lint:fixtures-parity",
    "db:extensions:local": "node scripts/with-env.mjs node scripts/enable-pgvector.mjs",
    "db:migrate:local": "dotenv -e .env.local -- drizzle-kit migrate --config .config/drizzle.config.ts && pnpm run lint:fixtures-parity",
    "db:migrate:vercel": "dotenv -e .env.vercel -- drizzle-kit migrate --config .config/drizzle.config.ts && pnpm run lint:fixtures-parity",
    "db:push": "drizzle-kit push --config .config/drizzle.config.ts",
    "db:push:local": "dotenv -e .env.local -- drizzle-kit push --config .config/drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config .config/drizzle.config.ts",
    "db:studio:local": "dotenv -e .env.local -- drizzle-kit studio --config .config/drizzle.config.ts",
    "icons:favicon": "node scripts/generate-favicon.mjs",
    "knip": "knip --no-progress --config .config/knip.json",
    "knip:production": "knip --no-progress --production --config .config/knip.json",
    "ai:gateway:smoke": "tsx scripts/ai-gateway-stream-text.ts",
    "ai:gateway:image": "tsx scripts/ai-gateway-generate-image.ts",
    "codex:sdk:smoke": "node scripts/with-env.mjs tsx scripts/codex-sdk-smoke.ts",
    "simulate:replay": "node scripts/with-env.mjs tsx scripts/simulate-replay.ts",
    "simulate:clear": "node scripts/with-env.mjs tsx scripts/simulate-clear.ts",
    "lynx:seed-demo": "node scripts/with-env.mjs tsx scripts/seed-lynx-demo.ts",
    "dev:seed": "node scripts/with-env.mjs node scripts/seed-dev-users.mjs",
    "openstatus:sync-ci": "node scripts/with-env.mjs node scripts/openstatus-sync-ci.mjs",
    "openstatus:env-hints": "node scripts/with-env.mjs node scripts/openstatus-env-hints.mjs",
    "openstatus:validate-feed": "node scripts/with-env.mjs node scripts/validate-openstatus-feed.mjs"
  },
  "dependencies": {
    "@ai-sdk/gateway": "^3.0.110",
    "@ai-sdk/openai": "^3.0.62",
    "@base-ui/react": "^1.4.1",
    "@better-auth/infra": "0.2.5",
    "@better-auth/passkey": "1.4.9",
    "@hookform/resolvers": "^5.2.2",
    "@neondatabase/auth": "0.3.0-beta",
    "@neondatabase/serverless": "^1.1.0",
    "@openai/codex-sdk": "^0.130.0",
    "@opentelemetry/api": "^1.9.1",
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@rive-app/react-webgl2": "^4.28.3",
    "@sentry/nextjs": "^10.52.0",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@tanstack/react-table": "^8.21.3",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "@vercel/blob": "^2.3.3",
    "@vercel/otel": "^2.1.2",
    "@vercel/sandbox": "^1.10.0",
    "@xyflow/react": "^12.10.2",
    "ai": "^6.0.175",
    "ansi-to-react": "^6.2.6",
    "better-auth": "1.4.9",
    "chrono-node": "^2.9.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "embla-carousel-react": "^8.6.0",
    "flags": "^4.0.6",
    "html2canvas": "^1.4.1",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.14.0",
    "media-chrome": "^4.19.0",
    "motion": "^12.38.0",
    "nanoid": "^5.1.11",
    "next": "16.2.4",
    "next-intl": "^4.11.0",
    "next-themes": "^0.4.6",
    "nuqs": "^2.8.9",
    "pino": "^10.3.1",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.75.0",
    "react-jsx-parser": "^2.4.1",
    "react-resizable-panels": "^4.11.0",
    "recharts": "3.8.0",
    "resend": "^6.12.2",
    "rrule": "^2.8.1",
    "server-only": "^0.0.1",
    "shiki": "^4.0.2",
    "sonner": "^2.0.7",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.5.0",
    "tokenlens": "^1.3.1",
    "tw-animate-css": "^1.4.0",
    "use-stick-to-bottom": "^1.1.4",
    "vaul": "^1.1.2",
    "workflow": "^4.2.4",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@next/env": "16.2.4",
    "@openstatus/sdk-node": "^0.1.6",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@turbo/gen": "^2.9.12",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "knip": "^6.12.0",
    "lint-staged": "^17.0.3",
    "next-devtools-mcp": "0.3.10",
    "pg": "^8.20.0",
    "pino-pretty": "^13.1.3",
    "postcss": "^8",
    "postcss-load-config": "^6.0.1",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "shadcn": "^4.7.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.1",
    "to-ico": "^1.1.5",
    "ts-morph": "^28.0.0",
    "tsx": "^4.21.0",
    "turbo": "^2.9.12",
    "typescript": "^5.9.3",
    "vercel": "^48.6.0",
    "vitest": "^4.1.5"
  }
}
