{
  "name": "afenda-vercel",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.21.0",
  "engines": {
    "node": "24.x"
  },
  "imports": {
    "#components2": "./components2/index.ts",
    "#components2/*": "./components2/*",
    "#app-shell": "./components2/app-shell/index.ts",
    "#app-shell/client": "./components2/app-shell/client.ts",
    "#collections/*": "./.source/*",
    "#lib/*": "./lib/*",
    "#features/*": "./lib/features/*",
    "#i18n/*": "./i18n/*",
    "#flags": "./flags.ts"
  },
  "scripts": {
    "preinstall": "node scripts/check-agent-contract.mjs",
    "predev": "node scripts/clean-workflow-generated.mjs",
    "dev": "next dev --turbopack",
    "prebuild": "node scripts/clean-workflow-generated.mjs",
    "build": "node scripts/next-build-stable.mjs --webpack",
    "start": "next start",
    "gen": "node scripts/turbo-gen.mjs",
    "gate": "node scripts/gate.mjs",
    "gate:help": "node scripts/gate-help.mjs",
    "gate:dry-run": "node scripts/gate-dry-run.mjs",
    "gate:push": "pnpm verify:parallel",
    "gate:merge": "pnpm gate:push && pnpm build",
    "lint:path": "node scripts/lint-path.mjs",
    "lint:full": "node scripts/turbo-with-env.mjs run lint:agent-contract lint:drizzle-journal lint:route-error-files lint:public-lynx-contract lint:fixtures-parity lint:eslint lint:design-contract lint:ask-docs-links lint:ask-docs-prose lint:ask-docs-quality lint:components2-renderers lint:renderer-contracts lint:renderer-container-queries lint:renderer-skeleton-parity lint:renderer-fixtures lint:list-surface-table-imports lint:feature-table-imports --output-logs=new-only",
    "lint": "pnpm run lint:full",
    "lint:a11y": "eslint . -c .config/eslint-a11y.config.mjs --report-unused-disable-directives --max-warnings 0",
    "lint:agent-contract": "node scripts/check-agent-contract.mjs",
    "lint:drizzle-journal": "node scripts/check-drizzle-journal.mjs",
    "lint:route-error-files": "node scripts/check-route-error-files.mjs",
    "lint:public-lynx-contract": "node scripts/check-public-lynx-contract.mjs",
    "lint:fixtures-parity": "node scripts/with-env.mjs pnpm exec vitest run tests/unit/fixtures-i18n-parity.test.ts --config .config/vitest.config.ts",
    "lint:eslint": "eslint . --max-warnings 0 --report-unused-disable-directives --cache --cache-location .artifacts/.eslintcache --cache-strategy content",
    "lint:design-contract": "node scripts/check-design-contract.mjs",
    "lint:ask-docs-links": "pnpm exec tsx scripts/validate-ask-docs-links.ts",
    "lint:ask-docs-prose": "node scripts/lint-ask-docs-prose.mjs",
    "lint:ask-docs-quality": "node scripts/lint-ask-docs-quality.mjs",
    "audit:ask-docs-quality": "node scripts/audit-ask-docs-quality.mjs",
    "ask-docs:check": "node scripts/ask-docs-check-gate.mjs",
    "ask-docs:validate-manifest": "node scripts/ask-docs-scaffold-from-manifest.mjs --validate-only",
    "ask-docs:scaffold": "node scripts/ask-docs-scaffold-from-manifest.mjs",
    "ask-docs:scaffold:dry-run": "node scripts/ask-docs-scaffold-from-manifest.mjs --dry-run --manifest tests/fixtures/ask-docs-scaffold-dry-run.manifest.json",
    "ask-docs:preflight": "pnpm ask-docs:validate-manifest && pnpm ask-docs:scaffold:dry-run && pnpm ask-docs:check",
    "lint:components2-renderers": "node scripts/check-components2-renderers.mjs",
    "lint:renderer-contracts": "node scripts/check-renderer-contracts.mjs",
    "lint:renderer-container-queries": "node scripts/check-renderer-container-queries.mjs",
    "lint:renderer-skeleton-parity": "node scripts/check-renderer-skeleton-parity.mjs",
    "lint:renderer-fixtures": "node scripts/check-renderer-fixtures.mjs",
    "lint:list-surface-table-imports": "node scripts/check-list-surface-table-imports.mjs",
    "lint:feature-table-imports": "node scripts/check-feature-table-imports.mjs",
    "gen:registry": "npx shadcn build",
    "format": "prettier --write --cache --cache-location .artifacts/.prettiercache \"**/*.{ts,tsx,mjs,css,json}\"",
    "format:check": "prettier --check --cache --cache-location .artifacts/.prettiercache \"**/*.{ts,tsx,mjs,css,json}\"",
    "pretypecheck": "next typegen",
    "typecheck": "node --max-old-space-size=8192 node_modules/typescript/bin/tsc --noEmit",
    "typecheck:test": "tsc --noEmit -p .config/tsconfig.test.json",
    "typecheck:scripts": "tsc --noEmit -p .config/tsconfig.scripts.json",
    "typecheck:full": "pnpm typecheck && pnpm typecheck:test && pnpm typecheck:scripts",
    "test": "vitest --config .config/vitest.config.ts",
    "test:fast": "node scripts/with-env.mjs vitest run --config .config/vitest.config.ts",
    "test:coverage": "node scripts/with-env.mjs vitest run --config .config/vitest.config.ts --coverage",
    "test:analyze:imports": "node scripts/with-env.mjs vitest run --config .config/vitest.config.ts --experimental.importDurations.print=true --experimental.importDurations.limit=30",
    "test:analyze:imports:warn": "node scripts/with-env.mjs vitest run --config .config/vitest.config.ts --experimental.importDurations.print=on-warn --experimental.importDurations.limit=30",
    "test:ci": "node scripts/with-env.mjs vitest run --config .config/vitest.config.ts --coverage",
    "test:ci:shard": "node scripts/with-env.mjs vitest run --config .config/vitest.config.ts --coverage --reporter=blob --shard=$SHARD",
    "test:ci:merge": "node scripts/with-env.mjs vitest run --config .config/vitest.config.ts --coverage --merge-reports=.vitest-reports",
    "test:e2e": "pnpm build && node scripts/with-env.mjs playwright test --config .config/playwright.config.ts",
    "test:e2e:smoke": "pnpm build && node scripts/with-env.mjs playwright test --config .config/playwright.config.ts --grep @smoke",
    "test:e2e:ci": "pnpm build && node scripts/with-env.mjs playwright test --config .config/playwright.config.ts",
    "integrity:static": "concurrently -n lint,tc,tc:test,tc:scripts,knip,fmt -c auto \"pnpm lint\" \"pnpm typecheck\" \"pnpm typecheck:test\" \"pnpm typecheck:scripts\" \"pnpm knip\" \"pnpm format:check\"",
    "integrity:behavior": "pnpm test:fast",
    "verify": "node scripts/turbo-with-env.mjs run lint:agent-contract lint:drizzle-journal lint:route-error-files lint:public-lynx-contract lint:fixtures-parity lint:eslint lint:design-contract lint:ask-docs-links lint:ask-docs-prose lint:ask-docs-quality lint:components2-renderers lint:renderer-contracts lint:renderer-container-queries lint:renderer-skeleton-parity lint:renderer-fixtures lint:list-surface-table-imports lint:feature-table-imports typecheck typecheck:test typecheck:scripts knip test:ci format:check --output-logs=new-only",
    "verify:ci": "node scripts/turbo-with-env.mjs run lint:agent-contract lint:drizzle-journal lint:route-error-files lint:public-lynx-contract lint:fixtures-parity lint:eslint lint:design-contract lint:ask-docs-links lint:ask-docs-prose lint:ask-docs-quality lint:components2-renderers lint:renderer-contracts lint:renderer-container-queries lint:renderer-skeleton-parity lint:renderer-fixtures lint:list-surface-table-imports lint:feature-table-imports typecheck typecheck:test typecheck:scripts knip test:ci format:check --concurrency=8 --output-logs=errors-only",
    "verify:no-test": "node scripts/turbo-with-env.mjs run lint:agent-contract lint:drizzle-journal lint:route-error-files lint:public-lynx-contract lint:fixtures-parity lint:eslint lint:design-contract lint:ask-docs-links lint:ask-docs-prose lint:ask-docs-quality lint:components2-renderers lint:renderer-contracts lint:renderer-container-queries lint:renderer-skeleton-parity lint:renderer-fixtures lint:list-surface-table-imports lint:feature-table-imports typecheck typecheck:test typecheck:scripts knip format:check --concurrency=8 --output-logs=errors-only",
    "verify:parallel": "node scripts/turbo-with-env.mjs run lint:agent-contract lint:drizzle-journal lint:route-error-files lint:public-lynx-contract lint:fixtures-parity lint:eslint lint:design-contract lint:ask-docs-links lint:ask-docs-prose lint:ask-docs-quality lint:components2-renderers lint:renderer-contracts lint:renderer-container-queries lint:renderer-skeleton-parity lint:renderer-fixtures lint:list-surface-table-imports lint:feature-table-imports typecheck typecheck:test typecheck:scripts knip test:ci format:check --output-logs=new-only",
    "verify:quick": "concurrently -n tc,tc:test,tc:scripts -c auto \"pnpm typecheck\" \"pnpm typecheck:test\" \"pnpm typecheck:scripts\" && pnpm integrity:behavior",
    "verify:artifact": "pnpm lint && pnpm typecheck && pnpm build",
    "smoke": "pnpm verify:artifact",
    "prepare": "husky",
    "env:sync": "node scripts/sync-env.mjs",
    "sentry": "sentry-cli",
    "validate:legal-declarations": "node scripts/with-env.mjs tsx scripts/validate-legal-declarations.ts",
    "verify:upstash": "node --env-file=.env.local scripts/verify-upstash-redis.mjs",
    "env:push-vercel": "node scripts/push-vercel-env.mjs",
    "env:repair-vercel-cron": "node scripts/repair-vercel-cron-secret.mjs",
    "env:pull-vercel": "vercel env pull .env.vercel",
    "env:vercel": "pnpm env:pull-vercel",
    "neon-auth:configure": "node scripts/configure-neon-auth.mjs",
    "shadcn:info": "shadcn info --json",
    "db:generate": "drizzle-kit generate --config .config/drizzle.config.ts",
    "db:migrate": "node scripts/drizzle-migrate-logged.mjs && pnpm run lint:fixtures-parity",
    "db:extensions:local": "node scripts/with-env.mjs node scripts/enable-pgvector.mjs",
    "db:migrate:local": "node scripts/with-env.mjs node scripts/drizzle-migrate-logged.mjs && pnpm run lint:fixtures-parity",
    "db:migrate:vercel": "node scripts/with-env.mjs --env-file=.env.vercel node scripts/drizzle-migrate-logged.mjs && pnpm run lint:fixtures-parity",
    "db:push": "node scripts/forbid-db-push.mjs",
    "db:push:local": "node scripts/forbid-db-push.mjs",
    "db:studio": "drizzle-kit studio --config .config/drizzle.config.ts",
    "db:studio:local": "dotenv -e .env.local -- drizzle-kit studio --config .config/drizzle.config.ts",
    "icons:favicon": "node scripts/generate-favicon.mjs",
    "knip": "knip --no-progress --config .config/knip.json",
    "knip:production": "knip --no-progress --production --config .config/knip.json",
    "ai:gateway:smoke": "tsx scripts/ai-gateway-stream-text.ts",
    "ai:gateway:image": "tsx scripts/ai-gateway-generate-image.ts",
    "simulate:replay": "node scripts/with-env.mjs tsx scripts/simulate-replay.ts",
    "simulate:clear": "node scripts/with-env.mjs tsx scripts/simulate-clear.ts",
    "lynx:seed-demo": "node scripts/with-env.mjs tsx scripts/seed-lynx-demo.ts",
    "dev:seed": "node scripts/with-env.mjs node scripts/seed-dev-users.mjs",
    "openstatus:sync-ci": "node scripts/with-env.mjs node scripts/openstatus-sync-ci.mjs",
    "openstatus:env-hints": "node scripts/with-env.mjs node scripts/openstatus-env-hints.mjs",
    "openstatus:validate-feed": "node scripts/with-env.mjs node scripts/validate-openstatus-feed.mjs"
  },
