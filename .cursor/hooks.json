{
  "version": 1,
  "hooks": {
    "beforeShellExecution": [
      {
        "command": "node scripts/cursor-hooks/deny-forbidden-shell.mjs"
      }
    ],
    "afterFileEdit": [
      {
        "command": "node scripts/cursor-hooks/queue-l0-lint.mjs",
        "matchers": [
          { "filePattern": "app/**/*.{ts,tsx}" },
          { "filePattern": "lib/**/*.{ts,tsx}" },
          { "filePattern": "components2/**/*.{ts,tsx}" },
          { "filePattern": "i18n/**/*.{ts,tsx}" },
          { "filePattern": "tests/**/*.{ts,tsx}" },
          { "filePattern": "scripts/**/*.{mjs,cjs,js}" },
          { "filePattern": "proxy.ts" },
          { "filePattern": "next.config.ts" },
          { "filePattern": "eslint.config.mjs" }
        ]
      }
    ]
  }
}
