{
  "mcpServers": {
    "shadcn": {
      "type": "stdio",
      "command": "pnpm",
      "args": ["exec", "shadcn", "mcp"]
    },
    "vercel": {
      "url": "https://mcp.vercel.com"
    },
    "next-devtools": {
      "type": "stdio",
      "command": "node",
      "args": [
        "${workspaceFolder}/node_modules/next-devtools-mcp/dist/index.js"
      ]
    },
    "sentry": {
      "url": "https://mcp.sentry.dev/mcp/afenda/javascript-nextjs"
    },
    "context7": {
      "url": "https://mcp.context7.com/mcp"
    },
    "neon": {
      "type": "stdio",
      "command": "pnpm",
      "args": ["dlx", "@neondatabase/mcp-server-neon", "start"]
    }
  }
}
