{
  "compilerOptions": {
    "baseUrl": ".",
    // Internal `#…/*` aliases: mirror `package.json` → `imports` for Node + bundlers.
    "paths": {
      "#components/*": ["./components/*"],
      "#components2/*": ["./components2/*"],
      "#app-shell": ["./components2/app-shell/index.ts"],
      "#lib/*": ["./lib/*"],
      "#hooks/*": ["./hooks/*"],
      "#features/*": ["./lib/features/*"],
      "#i18n/*": ["./i18n/*"]
    },
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolvePackageJsonImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "tsBuildInfoFile": ".artifacts/.tsbuildinfo/main",
    "forceConsistentCasingInFileNames": true,
    // Assume a file change only affects files that directly import it — avoids rechecking
    // the full transitive closure on every save in watch mode (IDE language-server + tsc --watch).
    "assumeChangesOnlyAffectDirectDependencies": true,
    "plugins": [
      {
        "name": "next"
      },
      {
        "name": "workflow"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "i18n/global.d.ts",
    "**/*.ts",
    "**/*.tsx",
    // Production typed routes only. next-env.d.ts already imports .next/dev/types/routes.d.ts
    // via an `import` statement — do not add .next/dev/types/** here (redundant, AGENTS.md §8).
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  // tests/ and scripts/ have their own tsconfig (tsconfig.test.json / tsconfig.scripts.json)
  // so they don't pull Playwright + Vitest + seed-script types into the main compile graph.
  // Root-level tool configs are also excluded here and covered by their respective split tsconfigs:
  //   vitest.config.ts / vitest.setup.ts → tsconfig.test.json
  //   playwright.config.ts               → tsconfig.test.json
  //   drizzle.config.ts                  → tsconfig.scripts.json
  "exclude": [
    "node_modules",
    ".next/dev",
    "tests",
    "scripts",
    "turbo",
    "vitest.config.ts",
    "vitest.setup.ts",
    "playwright.config.ts",
    "drizzle.config.ts"
  ]
}
