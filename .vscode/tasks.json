{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "pnpm: gate (L0 — pass paths after --)",
      "type": "shell",
      "command": "pnpm gate --",
      "problemMatcher": ["$eslint-stylish", "$tsc"],
      "group": "test",
      "presentation": { "reveal": "silent", "panel": "shared" }
    },
    {
      "label": "pnpm: typecheck",
      "type": "shell",
      "command": "pnpm run typecheck",
      "problemMatcher": "$tsc",
      "group": "build"
    },
    {
      "label": "pnpm: format:check",
      "type": "shell",
      "command": "pnpm run format:check",
      "problemMatcher": [],
      "group": "test"
    },
    {
      "label": "pnpm: smoke",
      "type": "shell",
      "command": "pnpm run smoke",
      "problemMatcher": [],
      "group": { "kind": "build", "isDefault": true }
    }
  ]
}
