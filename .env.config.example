# =============================================================================
# Maintainer env template → copy to `.env.config` (gitignored), edit there.
# Generated for tools: `pnpm env:sync` writes `.env.local` (Next.js + Drizzle).
# Do not commit `.env.config` or `.env.local`.
# =============================================================================
#
# Quick start
#   1. cp .env.config.example .env.config
#   2. Fill values in `.env.config`
#   3. pnpm env:sync
#   4. pnpm dev
#
# Re-run `env:sync` after changing `.env.config`. Keys that exist only in
# `.env.local` are kept at the bottom of the generated file (machine-only).
#
# Vercel
#   Set the same names in Project → Settings → Environment Variables, or:
#   vercel env pull .env.vercel
#   Optional push from local config: pnpm env:push-vercel (see scripts/push-vercel-env.mjs)
#   Production checklist: BETTER_AUTH_URL + NEXT_PUBLIC_SITE_URL (same canonical https origin);
#   BETTER_AUTH_TRUSTED_ORIGINS lists every host that serves the app (apex, www, redirects);
#   OTEL_SERVICE_NAME optional for stable Vercel tracing (instrumentation.ts).
#
# Next.js (see https://nextjs.org/docs/app/building-your-application/configuring/environment-variables)
#   • `NEXT_PUBLIC_*` is inlined into the browser bundle — never put secrets there.
#   • Other names are server-only (Route Handlers, Server Components, CLI).
#   • Load order: `.env` → `.env.[mode]` → `.env.local` → `.env.[mode].local`
#     (this repo uses `.env.local` produced from `.env.config`).
#
# Sections:  A Public (client)  B Auth  C Database  D Vercel features
#            E Observability  F Optional integrations  G Tooling  H Debug
# =============================================================================

# -----------------------------------------------------------------------------
# A. Public — sent to the browser (prefix required: NEXT_PUBLIC_)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME=MyApp
# Canonical site URL: metadataBase, OG, sitemap, robots. Production: https://your-domain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Legacy alias if NEXT_PUBLIC_SITE_URL is unset (lib/site.ts getSiteUrl)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_STAGE=dev
# Better Auth Infrastructure — client bundle must match server plugins (build-time flags).
# When server has BETTER_AUTH_API_KEY (§B), set NEXT_PUBLIC_BETTER_AUTH_INFRA=1 so dashClient loads.
# If server uses BETTER_AUTH_INFRA_SENTINEL=1, set NEXT_PUBLIC_BETTER_AUTH_INFRA_SENTINEL=1 here too.
# NEXT_PUBLIC_BETTER_AUTH_INFRA=0
# NEXT_PUBLIC_BETTER_AUTH_INFRA_SENTINEL=0
# NEXT_PUBLIC_TENANT_ROOT_DOMAIN=

# -----------------------------------------------------------------------------
# B. Better Auth — server only
# -----------------------------------------------------------------------------
BETTER_AUTH_SECRET=
# Optional comma-separated previous secrets for rotation (see Better Auth `secrets` / BETTER_AUTH_SECRETS)
# BETTER_AUTH_SECRETS=
# Must match the origin users use (scheme + host); align with NEXT_PUBLIC_SITE_URL in prod
BETTER_AUTH_URL=http://localhost:3000
# Comma-separated extra origins. lib/site.ts derives Better Auth hosts, trustedOrigins, and Next.js
# serverActions.allowedOrigins from BETTER_AUTH_URL + NEXT_PUBLIC_SITE_URL + this CSV.
# On Vercel, *.vercel.app is included when VERCEL is set; preview adds *.vercel.app in next.config.ts too.
# BETTER_AUTH_TRUSTED_ORIGINS=https://your-production-domain.com
# Comma-separated Better Auth user IDs with admin plugin access (optional; otherwise use role "admin")
# BETTER_AUTH_ADMIN_USER_IDS=
# Set to 1 to require a valid pending org invitation for email/password sign-up
# BETTER_AUTH_INVITE_ONLY_SIGNUP=0
# Set to 1 so accepting/rejecting org invitations requires verified email (Better Auth organization plugin)
# BETTER_AUTH_REQUIRE_EMAIL_VERIFICATION_ON_INVITATION=0
# Optional — HMAC key for streamed org audit CSV footer signatures (#signature_sha256 in export).
# Falls back to BETTER_AUTH_SECRET when unset. Verify offline with verifyOrganizationIamAuditExportCsv
# in lib/auth/org-audit.server.ts (same org id + secret used at export time). Rotate by setting a new
# secret; existing downloads verify only with the secret that produced them.
# ORG_AUDIT_EXPORT_HMAC_SECRET=
# Rolling-window cap on org.member.invite per actor per org (unset defaults to 30; 0 = unlimited).
# Without Upstash (below), enforcement uses iam_audit_event rows (same-instance caveats on fluid compute).
# ORG_INVITE_MAX_PER_HOUR=30
# Optional — Upstash Redis via Vercel Marketplace: durable sliding-window limits across all regions/instances.
# When both are set, invite rate limiting uses @upstash/ratelimit instead of the audit-table fallback.
# @see https://github.com/upstash/redis-js#basic-usage — REST URL + token (not redis:// TCP).
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# Optional: disable @upstash/redis anonymous telemetry
# UPSTASH_DISABLE_TELEMETRY=1
# WebAuthn RP ID override (default: hostname of BETTER_AUTH_URL)
# PASSKEY_RP_ID=localhost
# Better Auth Infrastructure: enables dash() when BETTER_AUTH_API_KEY is set (see §A NEXT_PUBLIC_* parity).
# BETTER_AUTH_API_KEY=
# Optional overrides for dash() + sentinel() (omit to use infrastructure defaults).
# apiUrl — Better Auth Infrastructure API base URL (DashOptions / SentinelOptions).
# kvUrl — KV / identify endpoint for caching & Sentinel (client falls back to https://kv.better-auth.com).
# @see https://better-auth.com/docs/infrastructure/plugins/dash#dashoptions
# @see https://better-auth.com/docs/infrastructure/plugins/sentinel#sentineloptions
# BETTER_AUTH_API_URL=
# BETTER_AUTH_KV_URL=
# Optional abuse-protection plugin (Infrastructure pro): set to 1 with BETTER_AUTH_API_KEY
# BETTER_AUTH_INFRA_SENTINEL=0

# OAuth — optional; wired in lib/auth/config.server.ts when both ID and secret are set
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Email (Resend) — optional; without RESEND_API_KEY, auth emails log in dev only
# RESEND_API_KEY=
# RESEND_FROM=Afenda <onboarding@resend.dev>

# -----------------------------------------------------------------------------
# C. Database (Drizzle + Neon)
# -----------------------------------------------------------------------------
# Neon metadata (optional; Neon MCP: describe_project, get_connection_string)
# NEON_API_KEY=
# NEON_ORG_ID=
# NEON_PROJECT_ID=
# NEON_PROJECT_NAME=
# NEON_BRANCH_ID=
# NEON_BRANCH_NAME=
# NEON_DATABASE_NAME=neondb
# NEON_DB_ROLE=neondb_owner
# NEON_REGION=
# NEON_PROXY_HOST=
# NEON_PG_VERSION=
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
# Optional: unpooled/direct URL for long DDL or migration tooling (see Neon "choose connection").
# DATABASE_URL_UNPOOLED=

# -----------------------------------------------------------------------------
# C.1 Knowledge / pgvector embeddings (Server Actions — `lib/features/knowledge`)
# -----------------------------------------------------------------------------
# Required to ingest chunks and run similarity search in the org dashboard Knowledge module.
OPENAI_API_KEY=
# Optional override (default: text-embedding-3-small). Output dimension must stay 1536 for `knowledge_chunk.embedding`.
# EMBEDDING_MODEL=text-embedding-3-small
# Lynx Phase 1 truth retrieval (`/api/erp/lynx/truth-search`, Vercel AI SDK `streamText`). Optional; default `gpt-4o-mini`.
# LYNX_GENERATION_MODEL=gpt-4o-mini
# Optional — Vercel AI Gateway (preferred on Vercel for Lynx **generation**). When set, Lynx uses the gateway instead of direct OpenAI for `streamText`.
# Model ids use `provider/model` (e.g. `openai/gpt-4o-mini`). See https://vercel.com/docs/ai-gateway
# AI_GATEWAY_API_KEY=
# After `pnpm env:sync`, you can smoke-test the gateway locally:
#   `pnpm ai:gateway:smoke` — text stream (`openai/gpt-5.4`)
#   `pnpm ai:gateway:image` — Gemini image modality → file under `.artifacts/ai-gateway/`

# -----------------------------------------------------------------------------
# D. Vercel platform — Blob uploads, Cron
# -----------------------------------------------------------------------------
# Product uploads today: Vercel Blob + /api/upload/blob. Do not mirror the same
# workflow on R2/S3 without updating AGENTS.md — R2 is for archive/evidence later.
BLOB_READ_WRITE_TOKEN=
# /api/cron/* expects Authorization: Bearer <CRON_SECRET> (e.g. app/api/cron/erp-jobs)
CRON_SECRET=

# -----------------------------------------------------------------------------
# E. Observability (server)
# -----------------------------------------------------------------------------
# Optional; @vercel/otel in instrumentation.ts — defaults to "afenda-vercel" if unset
# https://vercel.com/docs/tracing/instrumentation
OTEL_SERVICE_NAME=
# IAM audit JSON lines to stdout (Vercel Runtime Logs). On Vercel: enabled unless set to 0.
# Local dev: disabled unless set to 1. See IAM_AUDIT_TELEMETRY_TAG in lib/auth/iam-audit-telemetry.shared.ts.
# AFENDA_IAM_AUDIT_LOG=

# -----------------------------------------------------------------------------
# F. Optional integrations
# -----------------------------------------------------------------------------
# Upstash Redis (duplicate keys — keep in sync with section B if you use both)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# S3-compatible (e.g. R2) — policy: long-lived / audit evidence archive only
# (implementation enters roadmap after IAM audit semantics are stable).
# STORAGE_PROVIDER=r2
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_ENDPOINT=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_BUCKET=
# S3_ENDPOINT=
# S3_REGION=auto

# Email
# RESEND_API_KEY=
# AUTH_FROM_EMAIL=
# AUTH_REPLY_TO_EMAIL=
# DEFAULT_FROM_EMAIL=
# DEFAULT_FROM_NAME=

# -----------------------------------------------------------------------------
# G. Tooling / CI (not required for pnpm dev)
# -----------------------------------------------------------------------------
# Playwright E2E — defaults to 127.0.0.1:3001 + `next start` (pnpm test:e2e runs `pnpm build` first).
# Optional: same as BASE_URL — when set, Playwright does not start webServer (you supply the app).
# PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000
# BASE_URL=http://127.0.0.1:3000
# TURBO_TEAM=
# TURBO_TOKEN=
# VERCEL_TOKEN=
# GITHUB_TOKEN=

# -----------------------------------------------------------------------------
# H. Debug / build
# -----------------------------------------------------------------------------
# SKIP_ENV_VALIDATION=1

# -----------------------------------------------------------------------------
# Reference — injected on Vercel (do not set for normal local dev)
# -----------------------------------------------------------------------------
# VERCEL_URL, VERCEL_ENV, NODE_ENV — provided by the platform / runtime
#
# Inventory — used by app code today:
#   DATABASE_URL, BETTER_AUTH_SECRET, BETTER_AUTH_URL, BETTER_AUTH_TRUSTED_ORIGINS,
#   NEXT_PUBLIC_SITE_URL | NEXT_PUBLIC_APP_URL, CRON_SECRET, BLOB_READ_WRITE_TOKEN (Blob SDK),
#   OTEL_SERVICE_NAME; build/runtime: NEXT_PHASE, NEXT_RUNTIME, VERCEL_* (platform).
# Sections F–G: not imported yet — fill when you add features; pnpm env:push-vercel syncs F when set.
