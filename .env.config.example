# =============================================================================
# Maintainer env template → copy to `.env.config` (gitignored), edit there.
# Generated for tools: `pnpm env:sync` writes `.env.local` (Next.js + Drizzle).
# Do not commit `.env.config` or `.env.local`.
# =============================================================================
#
# Quick start
#   1. cp .env.config.example .env.config
#   2. Fill values in `.env.config`
#   3. pnpm env:sync
#   4. pnpm dev
#
# Re-run `env:sync` after changing `.env.config`. Keys that exist only in
# `.env.local` are kept at the bottom of the generated file (machine-only).
#
# Vercel
#   Set the same names in Project → Settings → Environment Variables, or:
#   vercel env pull .env.vercel
#   Optional push from local config: pnpm env:push-vercel (see scripts/push-vercel-env.mjs)
#   Production checklist: BETTER_AUTH_URL + NEXT_PUBLIC_SITE_URL (same canonical https origin);
#   BETTER_AUTH_TRUSTED_ORIGINS lists every host that serves the app (apex, www, redirects);
#   OTEL_SERVICE_NAME optional for stable Vercel tracing (instrumentation.ts).
#
# Cursor MCP validation (see AGENTS.md §5 — Validating with Neon and Vercel MCP)
#   • Neon MCP: describe_project / describe_branch / compare_database_schema / run_sql (read-only checks).
#   • Vercel MCP: get_project (teamId + projectId from .vercel/project.json), search_vercel_documentation.
#
# Next.js (see https://nextjs.org/docs/app/building-your-application/configuring/environment-variables)
#   • `NEXT_PUBLIC_*` is inlined into the browser bundle — never put secrets there.
#   • Other names are server-only (Route Handlers, Server Components, CLI).
#   • Load order: `.env` → `.env.[mode]` → `.env.local` → `.env.[mode].local`
#     (this repo uses `.env.local` produced from `.env.config`).
#
# Sections:  A Public (client)  B Auth  C Database  C.1 Knowledge  D Vercel
#            E Observability  K OpenStatus  F Optional integrations  G Tooling  H Debug
# =============================================================================

# -----------------------------------------------------------------------------
# A. Public — sent to the browser (prefix required: NEXT_PUBLIC_)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME=MyApp
# Canonical site URL: metadataBase, OG, sitemap, robots. Production: https://your-domain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Legacy alias if NEXT_PUBLIC_SITE_URL is unset (lib/site.ts getSiteUrl)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_STAGE=dev
# Better Auth Infrastructure — client bundle must match server plugins (build-time flags).
# When server has BETTER_AUTH_API_KEY (§B), set NEXT_PUBLIC_BETTER_AUTH_INFRA=1 so dashClient loads.
# If server uses BETTER_AUTH_INFRA_SENTINEL=1, set NEXT_PUBLIC_BETTER_AUTH_INFRA_SENTINEL=1 here too.
# NEXT_PUBLIC_BETTER_AUTH_INFRA=0
# NEXT_PUBLIC_BETTER_AUTH_INFRA_SENTINEL=0
# NEXT_PUBLIC_TENANT_ROOT_DOMAIN=
# Optional — base URL for “Open in GitHub” on public ask-docs (no trailing slash).
# Example: https://github.com/your-org/your-repo/blob/main/content/ask-docs
# NEXT_PUBLIC_ASK_DOCS_GITHUB_URL=

# -----------------------------------------------------------------------------
# B. Better Auth — server only
# -----------------------------------------------------------------------------
BETTER_AUTH_SECRET=
# Optional comma-separated previous secrets for rotation (see Better Auth `secrets` / BETTER_AUTH_SECRETS)
# BETTER_AUTH_SECRETS=
# Must match the origin users use (scheme + host); align with NEXT_PUBLIC_SITE_URL in prod
# Workflow dev (port 3002): use `pnpm dev:stack` — generates `.env.workflow.local` via env:sync:workflow (ADR-0039)
BETTER_AUTH_URL=http://localhost:3000
# Comma-separated extra origins. lib/site.ts derives Better Auth hosts, trustedOrigins, and Next.js
# serverActions.allowedOrigins from BETTER_AUTH_URL + NEXT_PUBLIC_SITE_URL + this CSV.
# Include every hostname that serves the app (apex + www if both exist), or requests to the missing host
# return 500 from Better Auth dynamic baseURL resolution (e.g. /api/auth/dash/config).
# On Vercel, *.vercel.app is included when VERCEL is set; preview adds *.vercel.app in next.config.ts too.
# BETTER_AUTH_TRUSTED_ORIGINS=https://your-domain.com,https://www.your-domain.com
# Comma-separated Better Auth user IDs with admin plugin access (optional; otherwise use role "admin")
# BETTER_AUTH_ADMIN_USER_IDS=
# Set to 1 to require a valid pending org invitation for email/password sign-up
# BETTER_AUTH_INVITE_ONLY_SIGNUP=0
# Set to 1 so accepting/rejecting org invitations requires verified email (Better Auth organization plugin)
# BETTER_AUTH_REQUIRE_EMAIL_VERIFICATION_ON_INVITATION=0
# Optional — HMAC key for streamed org audit CSV footer signatures (#signature_sha256 in export).
# Falls back to BETTER_AUTH_SECRET when unset. Verify offline with verifyOrganizationIamAuditExportCsv
# in lib/auth/org-audit.server.ts (same org id + secret used at export time). Rotate by setting a new
# secret; existing downloads verify only with the secret that produced them.
# ORG_AUDIT_EXPORT_HMAC_SECRET=
# Rolling-window cap on org.member.invite per actor per org (unset defaults to 30; 0 = unlimited).
# Without Upstash (below), enforcement uses iam_audit_event rows (same-instance caveats on fluid compute).
# ORG_INVITE_MAX_PER_HOUR=30
# Optional — Upstash Redis via Vercel Marketplace: durable sliding-window limits across all regions/instances.
# When both are set, invite rate limiting uses @upstash/ratelimit instead of the audit-table fallback.
# @see https://github.com/upstash/redis-js#basic-usage — REST URL + token (not redis:// TCP).
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# Optional: disable @upstash/redis anonymous telemetry
# UPSTASH_DISABLE_TELEMETRY=1
# WebAuthn RP ID override (default: hostname of BETTER_AUTH_URL)
# PASSKEY_RP_ID=localhost
# Better Auth Infrastructure — Dashboard plugin (`dash()` + `dashClient()` when NEXT_PUBLIC_BETTER_AUTH_INFRA=1).
# @see https://better-auth.com/docs/infrastructure/plugins/dashboard
# Enables dash() when BETTER_AUTH_API_KEY is set (see §A NEXT_PUBLIC_* parity).
# BETTER_AUTH_API_KEY=
# Optional overrides for dash() + sentinel() (omit to use infrastructure defaults).
# apiUrl — Better Auth Infrastructure API base URL (DashOptions / SentinelOptions).
# kvUrl — KV / identify endpoint for caching & Sentinel (client falls back to https://kv.better-auth.com).
# @see https://better-auth.com/docs/infrastructure/plugins/dash#dashoptions
# @see https://better-auth.com/docs/infrastructure/plugins/sentinel#sentineloptions
# BETTER_AUTH_API_URL=
# BETTER_AUTH_KV_URL=
# Dash activity tracking (lastActiveAt on user). Opt-in: set to 1 after `pnpm db:migrate:local` (migration 0007).
# BETTER_AUTH_INFRA_ACTIVITY_TRACKING=0
# Update interval in ms (default 300000 = 5 minutes).
# BETTER_AUTH_INFRA_ACTIVITY_INTERVAL_MS=300000
# Optional abuse-protection plugin (Infrastructure pro): set to 1 with BETTER_AUTH_API_KEY
# BETTER_AUTH_INFRA_SENTINEL=0

# OAuth — optional; configured in Neon Auth project (social providers), not in-app Better Auth config
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Email (Resend) — optional; without RESEND_API_KEY, auth emails log in dev only
# RESEND_API_KEY=
# RESEND_FROM=Afenda <onboarding@resend.dev>

# -----------------------------------------------------------------------------
# C. Database (Drizzle + Neon)
# -----------------------------------------------------------------------------
# Neon metadata (optional; Neon MCP: describe_project, get_connection_string)
# NEON_API_KEY=
# NEON_ORG_ID=
# NEON_PROJECT_ID=
# NEON_PROJECT_NAME=
# NEON_BRANCH_ID=
# NEON_BRANCH_NAME=
# NEON_DATABASE_NAME=neondb
# NEON_DB_ROLE=neondb_owner
# NEON_REGION=
# NEON_PROXY_HOST=
# NEON_PG_VERSION=
#
# Runtime (`lib/db/index.ts`, Vercel serverless): prefer Neon’s **pooled** connection string
# (hostname contains `-pooler`) — see https://neon.tech/docs/connect/connection-pooling
# Vercel Marketplace Neon integration typically injects a pooled `DATABASE_URL`.
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
#
# Drizzle CLI migrations (`drizzle.config.ts`): when set, **`DATABASE_URL_UNPOOLED` wins** over
# `DATABASE_URL`. Use Neon’s **direct** connection string (no `-pooler`) for DDL-heavy migrate runs.
# Same guidance: https://neon.tech/docs/connect/connection-pooling — “Schema migrations → Direct”.
# DATABASE_URL_UNPOOLED=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# -----------------------------------------------------------------------------
# C.1 Vercel AI Gateway — Knowledge, Lynx, Public Lynx (all AI in this repo)
# -----------------------------------------------------------------------------
# Required locally for embeddings, Lynx generation, and Public Lynx chat.
# On Vercel deployments, VERCEL_OIDC_TOKEN is auto-injected — no static key required.
# Generate a key: Vercel dashboard → AI Gateway → API keys.
# Local OIDC alternative: `vercel link` then `vercel env pull` (token rotates every 12h).
AI_GATEWAY_API_KEY=
# Embedding model (gateway `provider/model` form). Default: openai/text-embedding-3-small (1536 dims).
# EMBEDDING_MODEL=openai/text-embedding-3-small
# Public Lynx (`/api/chat`) primary model — Gateway `provider/model` form.
# LYNX_PRIMARY_MODEL=openai/gpt-4o-mini
# Optional client label mirror for Ask Lynx header (defaults to code constant when unset).
# NEXT_PUBLIC_LYNX_PRIMARY_MODEL=openai/gpt-4o-mini
# Public Lynx fallback models (comma-separated). Unset → anthropic/claude-sonnet-4.6,google/gemini-2.5-flash
# LYNX_FALLBACK_MODELS=anthropic/claude-sonnet-4.6,google/gemini-2.5-flash
# LYNX_EMBEDDING_MODEL=openai/text-embedding-3-small
# Emergency fallback for truth_generation execution class (default: no fallback).
# AFENDA_AI_EMERGENCY_FALLBACK=1
# Lynx truth retrieval (`/api/erp/lynx/truth-search`) and NL→SQL demo. Gateway `provider/model` form.
# LYNX_GENERATION_MODEL=openai/gpt-4o-mini
# NL→SQL demo dataset: migration `drizzle/0008_lynx_demo_unicorn.sql`, then `pnpm lynx:seed-demo <organizationId>`
# LYNX_MAX_OUTPUT_TOKENS=4096
# LYNX_OPERATOR_MAX_OUTPUT_TOKENS=2048
# FLAGS_SECRET=  # node -e "console.log(crypto.randomBytes(32).toString('base64url'))"
# FLAG_LYNX_OPERATOR_ENABLED=1
# FLAG_LYNX_STRUCTURED_QUERY_DEMO_ENABLED=1
# FLAG_LYNX_OPERATOR_ORBIT_TOOLS_ENABLED=1
# FLAG_ORBIT_ADVANCED_OPERATOR_CONTROLS_ENABLED=1
# Comma-separated fallback models if primary fails (primary omitted). Unset → anthropic/claude-sonnet-4.6,google/gemini-2.5-flash
# LYNX_GATEWAY_MODEL_FALLBACKS=anthropic/claude-sonnet-4.6,google/gemini-2.5-flash
# After `pnpm env:sync`, smoke-test: `pnpm ai:gateway:smoke` · `pnpm ai:gateway:image`

# -----------------------------------------------------------------------------
# D. Vercel platform — Blob uploads, Cron
# -----------------------------------------------------------------------------
# Product uploads today: Vercel Blob + /api/upload/blob. Do not mirror the same
# workflow on R2/S3 without updating AGENTS.md — R2 is for archive/evidence later.
BLOB_READ_WRITE_TOKEN=
# /api/cron/* expects Authorization: Bearer <CRON_SECRET> (e.g. app/api/cron/erp-jobs)
CRON_SECRET=

# HRM time clock ingest — POST /api/erp/hrm/time-clock/ingest (machine callers)
# Bearer token + header x-afenda-organization-id must match batch organizationId.
# Per-device keys: store the same secret in device integrationCredentialRef.
# HRM_TIME_CLOCK_INGEST_API_KEY=
# HRM_TIME_CLOCK_INGEST_ACTOR_USER_ID=

# -----------------------------------------------------------------------------
# E. Observability (server)
# -----------------------------------------------------------------------------
# Optional; @vercel/otel in instrumentation.ts — defaults to "afenda-vercel" if unset
# https://vercel.com/docs/tracing/instrumentation
OTEL_SERVICE_NAME=
# Pino level (default: info in production, debug in development)
# LOG_LEVEL=debug
# Human-readable dev logs (optional). Uses pino-pretty worker — default off for Turbopack stability; JSON logs always work.
# LOG_PRETTY=1
#
# Sentry — incident inbox (optional). Server: SENTRY_DSN; browser: NEXT_PUBLIC_SENTRY_DSN (same DSN is typical).
# https://docs.sentry.io/platforms/javascript/guides/nextjs/
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
# Traces / profiles sampling (0.0–1.0). Defaults are conservative on server; Edge uses SENTRY_EDGE_TRACES_SAMPLE_RATE.
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_EDGE_TRACES_SAMPLE_RATE=0.05
# SENTRY_PROFILES_SAMPLE_RATE=0
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.05
#
# Source map upload (CI / Vercel): when all three are set, next.config wraps with withSentryConfig upload.
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=
#
# IAM audit JSON lines to stdout (Vercel Runtime Logs). On Vercel: enabled unless set to 0.
# Local dev: disabled unless set to 1. See IAM_AUDIT_TELEMETRY_TAG in lib/auth/iam-audit-telemetry.shared.ts.
# AFENDA_IAM_AUDIT_LOG=
#
# Operational simulation (non-production): scenario replay/clear Server Actions and `pnpm simulate:*` CLI.
# Do not enable on production tenants unless you intentionally accept simulated rows in org audit exports.
# AFENDA_ENABLE_SIMULATION=

# -----------------------------------------------------------------------------
# K. OpenStatus — public /status authority (`lib/features/public-trust`, `.openstatus/*`)
# -----------------------------------------------------------------------------
# OPENSTATUS_API_TOKEN — server-only (CLI `openstatus login`, workspace API key, or GitHub secret).
# OPENSTATUS_PUBLIC_STATUS_URL — status page **origin** only; Afenda appends `/feed/json`.
# Validate after changes: `pnpm openstatus:validate-feed`
# Regenerate URL/id/slug hints: `pnpm openstatus:env-hints` (CLI binary required).
# OPENSTATUS_WORKSPACE_SLUG — optional documentation only (not read by the Next.js app).
# OPENSTATUS_API_TOKEN=
# OPENSTATUS_STATUS_PAGE_ID=
# OPENSTATUS_STATUS_PAGE_SLUG=
# OPENSTATUS_WORKSPACE_SLUG=
# OPENSTATUS_PUBLIC_STATUS_URL=https://your-page.openstatus.dev
#
# Monitor-as-code + CI synthetics:
#   openstatus monitors apply --config .openstatus/production.yaml -y
#   pnpm openstatus:sync-ci

# -----------------------------------------------------------------------------
# F. Optional integrations
# -----------------------------------------------------------------------------
# Upstash Redis (duplicate keys — keep in sync with section B if you use both)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# S3-compatible (e.g. R2) — policy: long-lived / audit evidence archive only
# (implementation enters roadmap after IAM audit semantics are stable).
# STORAGE_PROVIDER=r2
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_ENDPOINT=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_BUCKET=
# S3_ENDPOINT=
# S3_REGION=auto

# Ably — org Messenger realtime (`ABLY_API_KEY` only: `keyName:keySecret` from Ably app).
# Server Actions publish after DB commit; `app/api/erp/messenger/auth` mints Ably token requests.
# Do not set `NEXT_PUBLIC_*` Ably secrets. Do not store Ably access-token JWTs here (they expire; the app mints tokens).
# ABLY_API_KEY=

# Org notifications — Web Push (optional; also uses ABLY_API_KEY for in-tab realtime refresh).
# Generate VAPID keys: `npx web-push generate-vapid-keys`
# NEXT_PUBLIC_ORG_PUSH_VAPID_PUBLIC_KEY=
# ORG_PUSH_VAPID_PRIVATE_KEY=
# ORG_PUSH_VAPID_SUBJECT=mailto:ops@example.com

# Email
# RESEND_API_KEY=
# AUTH_FROM_EMAIL=
# AUTH_REPLY_TO_EMAIL=
# DEFAULT_FROM_EMAIL=
# DEFAULT_FROM_NAME=

# -----------------------------------------------------------------------------
# G. Tooling / CI (not required for pnpm dev)
# -----------------------------------------------------------------------------
# Playwright E2E — see docs/testing/e2e-local-playbook.md (E0 preflight → E1 -g one test → E2 full suite at PR).
# Default harness: 127.0.0.1:3001 (`pnpm test:e2e` runs `pnpm build` first). `pnpm dev` stays on 3000.
# When `pnpm dev` on 3000 is healthy, Playwright auto-detects it; omit PLAYWRIGHT_BASE_URL if port 3000 is hung (TCP listen, no HTTP).
# If you set PLAYWRIGHT_BASE_URL, align BETTER_AUTH_URL + NEXT_PUBLIC_BETTER_AUTH_URL to the same host (localhost vs 127.0.0.1 breaks cookies).
# PLAYWRIGHT_BASE_URL=http://127.0.0.1:3001
# BETTER_AUTH_URL=http://127.0.0.1:3001
# NEXT_PUBLIC_BETTER_AUTH_URL=http://127.0.0.1:3001/api/auth
#
# Fast HRM time-clock gate (no browser): pnpm e2e:preflight:time-clock
#
# Org-admin E2E — enable after `pnpm env:sync` → `.env.local` (Playwright uses with-env.mjs).
# Requires `pnpm dev:seed` (+ `pnpm dev:seed:demo-erp` for HRM employee mapping specs).
# E2E_ORG_ADMIN_EMAIL=owner@afenda.com
# E2E_ORG_ADMIN_PASSWORD=<Better Auth password for that email>
# E2E_ORG_SLUG=demo-org
# HRM time-clock Bearer ingest branch (optional): HRM_TIME_CLOCK_INGEST_API_KEY=… HRM_TIME_CLOCK_INGEST_ACTOR_USER_ID=…
# Employee portal — owner@afenda.com must have active portal access on this slug (typically `{orgSlug}-employee`).
# E2E_EMPLOYEE_PORTAL_SLUG=demo-org-employee
#
# Turborepo (single-package mode — task cache for `pnpm verify` / `pnpm verify:ci`)
# Local: `./.turbo/` (gitignored). `pnpm lint` / `pnpm verify` load optional `TURBO_*` from here via
# scripts/turbo-with-env.mjs (`override: false` — CI/GitHub env always wins).
# Disable Vercel telemetry pings (https://turborepo.com/docs/telemetry). Recommended locally + enforced in CI.
TURBO_TELEMETRY_DISABLED=1
# Phase 2 — Vercel Remote Cache: link via `pnpm turbo login` + `pnpm turbo link`.
# Token = Vercel access token scoped to the team; team = slug, not ID.
# TURBO_TOKEN=
# TURBO_TEAM=jacks-projects-7b3cfe94
# Optional but strongly recommended for enterprise: HMAC signing of cache artifacts.
# Without it, anyone with TURBO_TOKEN can publish poisoned artifacts.
# https://turborepo.com/docs/core-concepts/remote-caching#artifact-integrity-and-authenticity-verification
# TURBO_REMOTE_CACHE_SIGNATURE_KEY=
# -----------------------------------------------------------------------------
# H. Debug / build
# -----------------------------------------------------------------------------
# SKIP_ENV_VALIDATION=1
# Floating dev sign-in shortcuts (`components/dev`) — set to 0 to hide during `pnpm dev`.
# NEXT_PUBLIC_DEV_SIGNIN_PANEL=0
# Route error debug panel on `app/**/error.tsx` — set to 0 to hide during `pnpm dev`.
# NEXT_PUBLIC_DEV_ERROR_PANEL=0

# -----------------------------------------------------------------------------
# I. Neon Auth (V2 transitional control-plane)
# -----------------------------------------------------------------------------
# Browser Neon Auth client (`@neondatabase/auth/next` createAuthClient): full URL of the **Next.js**
# auth proxy Route Handler (must end with `/api/auth`). If omitted, the client defaults to `{origin}/api/auth`,
# which only works when the app serves the catch-all route at that path.
# Local: match NEXT_PUBLIC_SITE_URL origin + path
# NEXT_PUBLIC_AUTH_URL=http://localhost:3000/api/auth
#
# Branch-scoped Neon Auth URL (Project -> Branch -> Auth -> Configuration)
# NEON_AUTH_BASE_URL=https://ep-xxxx.neonauth.<region>.aws.neon.tech/neondb/auth
# HMAC secret for Neon Auth session cookies (32+ chars)
# Generate with: openssl rand -base64 32
# NEON_AUTH_COOKIE_SECRET=
# Optional cookie domain for cross-subdomain sessions
# NEON_AUTH_COOKIE_DOMAIN=
# Optional session cache TTL (seconds) for createNeonAuth cookies.sessionDataTtl
# NEON_AUTH_SESSION_CACHE_TTL=300
# Control-plane metadata (scripts / diagnostics)
# NEON_AUTH_PROJECT_ID=
# NEON_AUTH_BRANCH_ID=
#
# Branch parity: DATABASE_URL must point at a branch that (1) has Neon Auth enabled in the Neon Console
# (so the neon_auth schema exists — not created by Drizzle), and (2) has received Drizzle migrations
# (pgvector, app tables). Vercel preview DB branches often miss (1) and/or (2) until configured.
# Optional explicit webhook target for Neon Auth events (must be HTTPS; use ngrok/vercel tunnel for local dev)
# NEON_AUTH_WEBHOOK_URL=https://your-public-host/api/integrations/neon-auth-webhooks
# Feature flag for locale auth/account route groups (`/[locale]/(auth)/**`, `/[locale]/(iam)/**`)
# AFENDA_NEON_AUTH_ENABLED=0
# NEXT_PUBLIC_AFENDA_NEON_AUTH_ENABLED=0

# Refactor gate — English-only active locales (ADR-0028). Set both, then `pnpm env:sync`.
# Resume full i18n before deploy — see docs/decisions/0028-single-locale-refactor-gate.md.
# Never enable in CI/Vercel production.
# AFENDA_I18N_SINGLE_LOCALE=1
# NEXT_PUBLIC_AFENDA_I18N_SINGLE_LOCALE=1

# -----------------------------------------------------------------------------
# Reference — injected on Vercel (do not set for normal local dev)
# -----------------------------------------------------------------------------
# VERCEL_URL, VERCEL_ENV, NODE_ENV — provided by the platform / runtime
#
# Inventory — used by app code today:
#   DATABASE_URL, DATABASE_URL_UNPOOLED (optional migrations), BETTER_AUTH_SECRET, BETTER_AUTH_URL, BETTER_AUTH_TRUSTED_ORIGINS,
#   NEXT_PUBLIC_SITE_URL | NEXT_PUBLIC_APP_URL, CRON_SECRET, BLOB_READ_WRITE_TOKEN (Blob SDK),
#   OTEL_SERVICE_NAME; build/runtime: NEXT_PHASE, NEXT_RUNTIME, VERCEL_* (platform).
# Sections F–G: not imported yet — fill when you add features; pnpm env:push-vercel syncs F when set.
