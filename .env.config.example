# =============================================================================
# Environment template — safe to commit. Copy → `.env.config` (gitignored).
# =============================================================================
# Workflow:
#   1. cp .env.config.example .env.config
#   2. Fill secrets locally (never commit `.env.config`)
#   3. pnpm env:sync   → writes `.env.local` for Next.js
#
# Vercel production: set the same keys in Project → Settings → Environment Variables,
# or use: vercel env pull .env.vercel  (compare / merge manually; file is gitignored)
# =============================================================================

# --- Public (exposed to browser; must prefix NEXT_PUBLIC_) --------------------
NEXT_PUBLIC_APP_NAME=MyApp
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_STAGE=dev
# NEXT_PUBLIC_BETTER_AUTH_INFRA=0
# NEXT_PUBLIC_TENANT_ROOT_DOMAIN=

# --- Better Auth (server) -----------------------------------------------------
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
# BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3000
# BETTER_AUTH_API_KEY=

# --- OAuth (optional; enable providers in lib/auth.ts when set) --------------
# BETTER_AUTH_GITHUB_CLIENT_ID=
# BETTER_AUTH_GITHUB_CLIENT_SECRET=
# BETTER_AUTH_GOOGLE_CLIENT_ID=
# BETTER_AUTH_GOOGLE_CLIENT_SECRET=
# BETTER_AUTH_LINKEDIN_CLIENT_ID=
# BETTER_AUTH_LINKEDIN_CLIENT_SECRET=

# --- Neon Postgres (see Neon MCP: describe_project, get_connection_string) ---
# NEON_API_KEY=
# NEON_ORG_ID=
# NEON_PROJECT_ID=
# NEON_PROJECT_NAME=
# NEON_BRANCH_ID=
# NEON_BRANCH_NAME=
# NEON_DATABASE_NAME=neondb
# NEON_DB_ROLE=neondb_owner
# NEON_REGION=
# NEON_PROXY_HOST=
# NEON_PG_VERSION=
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# --- Vercel (this app: Blob, Cron) -------------------------------------------
BLOB_READ_WRITE_TOKEN=
CRON_SECRET=

# --- Optional: Upstash / Redis ------------------------------------------------
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# --- Optional: object storage (S3-compatible e.g. R2) ---------------------------
# STORAGE_PROVIDER=r2
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_ENDPOINT=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_BUCKET=
# S3_ENDPOINT=
# S3_REGION=auto

# --- Email (optional) ---------------------------------------------------------
# RESEND_API_KEY=
# AUTH_FROM_EMAIL=
# AUTH_REPLY_TO_EMAIL=
# DEFAULT_FROM_EMAIL=
# DEFAULT_FROM_NAME=

# --- Tooling / CI only (never needed for `pnpm dev`) -------------------------
# TURBO_TEAM=
# TURBO_TOKEN=
# VERCEL_TOKEN=
# GITHUB_TOKEN=

# --- Build escape hatch -------------------------------------------------------
# SKIP_ENV_VALIDATION=1
