import { ORG_DASHBOARD_{{constantCase slug}} } from "../constants"
import { {{camelCase slug}}Schema } from "../schemas/{{slug}}.schema"
import type { {{pascalCase slug}}FormState } from "../types"

export async function {{camelCase verb}}{{pascalCase slug}}(
  _prevState: {{pascalCase slug}}FormState,
  formData: FormData
): Promise<{{pascalCase slug}}FormState> {
  // {{tier}} — see AGENTS.md §5 IAM audit policy.
{{#if isTierAOrS}}
  const { organizationId, userId, user } = await requireOrgSession()

  const allowed = await canActInOrganization(
    userId,
    user.role,
    organizationId,
    "{{requiredRole}}"
  )
  if (!allowed) {
    return {
      ok: false,
      errors: {
        form: "You do not have permission to {{verb}} this resource.",
      },
    }
  }
{{else}}
  const { organizationId, userId } = await requireOrgSession()
{{/if}}

  const parsed = {{camelCase slug}}Schema.safeParse({
    name: formData.get("name"),
  })

  if (!parsed.success) {
    const fieldErrors = parsed.error.flatten().fieldErrors
    return {
      ok: false,
      errors: {
        name: fieldErrors.name?.[0],
      },
    }
  }

  // TODO: persist — see JSDoc example above for the wiring pattern.
  // Scope every write with `organizationId` from the session (NEVER from
  // FormData). Once a real DB write exists, add the audit block.
  void parsed.data
  void organizationId
{{#unless isTierAOrS}}
  void userId
{{/unless}}

  revalidatePath(
    toLocaleOrgDashboardRevalidatePattern(ORG_DASHBOARD_{{constantCase slug}}),
    "page"
  )
  return { ok: true }
}
