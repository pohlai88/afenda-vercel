/**
 * Module-local constants for `lib/features/{{slug}}`.
 *
 * Generated by `pnpm gen capability` ({{date}}). The dashboard tail is
 * declared here (not in `lib/dashboard-module-paths.ts`) so the module owns
 * its own URL constant — central registries are reserved for cross-module
 * coordination only.
 *
 * Path builder uses `organizationDashboardPath` from `#lib/dashboard-module-paths`
 * once the module is registered there (Phase 2). For now it composes the
 * locale-internal pathname directly so this scaffold passes typecheck without
 * touching shared registries.
 */
import type { Route } from "next"

import { normalizeOrgSlugParam } from "#lib/org-slug.shared"

/** Locale-internal dashboard tail for `{{slug}}` (`toLocaleOrgDashboardRevalidatePattern`). */
export const ORG_DASHBOARD_{{constantCase slug}} = "/{{slug}}" as const

/**
 * Locale-internal pathname for the `{{slug}}` surface
 * (`localePrefix: "always"`, e.g. `/en/o/{slug}/dashboard/{{slug}}`).
 *
 * Returns a typed {@link Route} for `Link` / `redirect` from `#i18n/navigation`.
 */
export function {{camelCase slug}}DashboardPath(orgSlug: string): Route {
  const orgSlugSafe = normalizeOrgSlugParam(orgSlug)
  if (!orgSlugSafe) {
    throw new Error("{{camelCase slug}}DashboardPath: invalid org slug")
  }
  return `/o/${orgSlugSafe}/dashboard/{{slug}}` as Route
}
