/**
 * RSC page for `{{slug}}`. Composed under
 * `app/[locale]/o/[orgSlug]/dashboard/{{slug}}/page.tsx`.
 *
 * Generated by `pnpm gen capability` ({{date}}). Reads tenant truth in the
 * RSC body (no client-side ERP fetching) and renders the canonical card
 * shape used by other dashboard surfaces. Hardcoded labels are scaffolds —
 * extract to `messages/<locale>.json` once the surface stabilizes.
 */
import {
  Card,
  CardContent,
  CardDescription,
  CardHeader,
  CardTitle,
} from "#components/ui/card"
import { ModulePageHeader } from "#components/module-page-header"
import { requireOrgSession } from "#lib/tenant"

import { listFor{{pascalCase slug}}Organization } from "../data/{{slug}}.queries"
import type { {{pascalCase slug}}Row } from "../types"

export async function {{pascalCase slug}}Page() {
  const org = await requireOrgSession()
  const rows: {{pascalCase slug}}Row[] = await listFor{{pascalCase slug}}Organization(
    org.organizationId
  )

  return (
    <div className="flex flex-col gap-6">
      <ModulePageHeader
        title="{{titleCase slug}}"
        description="{{titleCase slug}} surface — wire to your real data layer."
        eyebrow="ERP"
      />

      <Card size="sm">
        <CardHeader>
          <CardTitle>Directory</CardTitle>
          <CardDescription>
            {rows.length === 0
              ? "No records yet — implement the query in `data/{{slug}}.queries.ts`."
              : `${rows.length} record${rows.length === 1 ? "" : "s"}.`}
          </CardDescription>
        </CardHeader>
        <CardContent className="flex flex-col gap-4">
          {rows.length === 0 ? (
            <p className="text-muted-foreground text-sm">
              The list will appear here once the Drizzle table is wired.
            </p>
          ) : (
            <ul className="divide-y">
              {rows.map((row) => (
                <li key={row.id} className="flex items-center gap-3 py-3">
                  <span className="text-foreground text-sm font-medium">
                    {row.name}
                  </span>
                </li>
              ))}
            </ul>
          )}
        </CardContent>
      </Card>
    </div>
  )
}
