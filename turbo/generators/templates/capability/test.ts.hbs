/**
 * Tenant-isolation contract for `{{slug}}`.
 *
 * Generated by `pnpm gen capability` ({{date}}). Mirrors the canonical
 * pattern in `tests/unit/contacts-org-scope.test.ts`. Verifies:
 *
 *   1. Every read filters by `organizationId` (via `eq(...)`).
 *   2. The Server Action uses `organizationId` from `requireOrgSession()`,
 *      never from untrusted `FormData`.
 *
 * Once you wire a real Drizzle table, expand the listing assertion to also
 * verify the columns being selected — see contacts test for details.
 */
import { beforeEach, describe, expect, it, vi } from "vitest"

const drizzleEqMocks = vi.hoisted(() => ({
  eqCalls: [] as unknown[][],
}))

vi.mock("drizzle-orm", async (importOriginal) => {
  const actual = await importOriginal<typeof import("drizzle-orm")>()
  return {
    ...actual,
    eq: (...args: unknown[]) => {
      drizzleEqMocks.eqCalls.push(args)
      return (actual.eq as (...a: unknown[]) => unknown)(...args)
    },
  }
})

vi.mock("#lib/db", () => ({
  db: {
    select: vi.fn(),
    insert: vi.fn(),
  },
}))

import { {{camelCase verb}}{{pascalCase slug}} } from "#features/{{slug}}/actions/{{verb}}-{{slug}}"
import { listFor{{pascalCase slug}}Organization } from "#features/{{slug}}/data/{{slug}}.queries"

vi.mock("#lib/auth", () => ({
  requireOrgSession: vi.fn(),
  writeIamAuditEventFromNextHeaders: vi.fn().mockResolvedValue(undefined),
  canActInOrganization: vi.fn().mockResolvedValue(true),
}))

vi.mock("next/cache", () => ({
  revalidatePath: vi.fn(),
}))

import { requireOrgSession } from "#lib/auth"

describe("{{slug}} org isolation", () => {
  beforeEach(() => {
    vi.mocked(requireOrgSession).mockReset()
    drizzleEqMocks.eqCalls = []
  })

  it("listFor{{pascalCase slug}}Organization returns a tenant-scoped array (stub returns [])", async () => {
    // Stub query returns []; once wired to Drizzle, replace with the
    // `drizzleEqMocks.eqCalls` pattern from contacts-org-scope.test.ts.
    const rowsA = await listFor{{pascalCase slug}}Organization("org-a")
    const rowsB = await listFor{{pascalCase slug}}Organization("org-b")
    expect(Array.isArray(rowsA)).toBe(true)
    expect(Array.isArray(rowsB)).toBe(true)
  })

  it("{{camelCase verb}}{{pascalCase slug}} resolves organizationId from requireOrgSession, not FormData", async () => {
    vi.mocked(requireOrgSession).mockResolvedValue({
      userId: "user-1",
      sessionId: "sess-1",
      organizationId: "org-session",
      user: { email: "a@b.com", name: null, role: "member" },
    })

    const fd = new FormData()
    fd.set("name", "Generated Demo")
    fd.set("organizationId", "org-evil")

    const result = await {{camelCase verb}}{{pascalCase slug}}(undefined, fd)
    // Stub action returns { ok: true } on valid input. The contract this
    // asserts is the call shape — `requireOrgSession()` must have been
    // invoked, proving the org came from the session not the FormData.
    expect(vi.mocked(requireOrgSession)).toHaveBeenCalled()
    expect(result).toEqual({ ok: true })
  })
})
