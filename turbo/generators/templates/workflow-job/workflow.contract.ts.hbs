/**
 * Workflow lifecycle audits for `{{camelCase jobName}}`.
 *
 * Generated by `pnpm gen workflow-job` ({{date}}). Lifecycle verbs
 * (`started`, `completed`, `failed`) are NOT CRUD-SAP verbs — they describe
 * a durable run's state machine, not a business mutation. We use
 * `buildErpAuditAction` (legacy permissive builder) here so the strings
 * still get sanitization while sidestepping the strict CRUD-SAP allowlist.
 *
 * Resulting audit shape (4 segments — matches AGENTS.md §5 audit policy):
 *
 *   erp.{{slug}}.{{auditObject}}_run.started
 *   erp.{{slug}}.{{auditObject}}_run.completed
 *   erp.{{slug}}.{{auditObject}}_run.failed
 *
 * @see lib/erp/crud-sap.shared.ts — `buildErpAuditAction`
 * @see lib/features/execution/execution.contract.ts — reference for lifecycle audits
 */
import { buildErpAuditAction } from "#lib/erp/crud-sap.shared"

export const {{constantCase jobName}}_WORKFLOW_AUDIT_ACTIONS = {
  {{camelCase jobName}}Started: buildErpAuditAction({
    area: "erp",
    module: "{{slug}}",
    object: "{{auditObject}}_run",
    verb: "started",
  }),
  {{camelCase jobName}}Completed: buildErpAuditAction({
    area: "erp",
    module: "{{slug}}",
    object: "{{auditObject}}_run",
    verb: "completed",
  }),
  {{camelCase jobName}}Failed: buildErpAuditAction({
    area: "erp",
    module: "{{slug}}",
    object: "{{auditObject}}_run",
    verb: "failed",
  }),
} as const

export type {{pascalCase jobName}}WorkflowAuditAction =
  (typeof {{constantCase jobName}}_WORKFLOW_AUDIT_ACTIONS)[keyof typeof {{constantCase jobName}}_WORKFLOW_AUDIT_ACTIONS]
