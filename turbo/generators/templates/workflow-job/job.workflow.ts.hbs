/**
 * Workflow DevKit durable job — `{{camelCase jobName}}`.
 *
 * Generated by `pnpm gen workflow-job` ({{date}}). Mirrors the canonical
 * shape of `lib/features/org-admin/data/import-job-run.workflow.ts`:
 *
 *   1. **`"use workflow"` orchestrator** — composes `"use step"` boundaries
 *      and audits lifecycle (`started → completed | failed`).
 *   2. **Idempotent steps** — each step can re-run on retry without
 *      double-writing state.
 *   3. **Tier classification stays in the caller** — Server Action / Route
 *      Handler enqueuing the workflow must call `requireOrgSession` (and
 *      `requireErpPermission(...)` for Tier A) before invoking it.
 *
 * Lifecycle audit strings live in `./{{jobName}}.workflow.contract.ts`.
 *
 * @see AGENTS.md §5 — Operational execution (Workflow DevKit)
 * @see lib/features/org-admin/data/import-job-run.workflow.ts — reference
 */
import { writeIamAuditEvent } from "#lib/auth"

import {
  {{constantCase jobName}}_WORKFLOW_AUDIT_ACTIONS,
} from "./{{jobName}}.workflow.contract"

/** Trusted payload — composed by the calling Server Action after tenant/role gates. */
export interface {{pascalCase jobName}}Payload {
  organizationId: string
  actorUserId: string | null
  actorSessionId: string | null
  /** Resource the run mutates (e.g. import job id, submission id). */
  resourceId: string
}

/**
 * Durable orchestrator — composes steps and writes lifecycle audits.
 * Tenant guards belong in the caller, not here.
 */
export async function run{{pascalCase jobName}}Workflow(
  payload: {{pascalCase jobName}}Payload
) {
  "use workflow"

  try {
    await {{camelCase jobName}}StartedStep(payload)
    await {{camelCase jobName}}WorkStep(payload)
    await {{camelCase jobName}}CompletedStep(payload)
  } catch (err) {
    await {{camelCase jobName}}FailedStep(payload, err)
    throw err
  }
}

async function {{camelCase jobName}}StartedStep(
  payload: {{pascalCase jobName}}Payload
) {
  "use step"

  await writeIamAuditEvent({
    action: {{constantCase jobName}}_WORKFLOW_AUDIT_ACTIONS.{{camelCase jobName}}Started,
    actorUserId: payload.actorUserId,
    actorSessionId: payload.actorSessionId,
    organizationId: payload.organizationId,
    resourceType: "{{slug}}.{{auditObject}}",
    resourceId: payload.resourceId,
    metadata: {},
  })
}

async function {{camelCase jobName}}WorkStep(payload: {{pascalCase jobName}}Payload) {
  "use step"

  // TODO: replace placeholder with the real durable work. Keep each step
  // idempotent — Workflow DevKit may retry on transient failure, so writes
  // here must be safe to repeat with the same payload.
  void payload
}

async function {{camelCase jobName}}CompletedStep(
  payload: {{pascalCase jobName}}Payload
) {
  "use step"

  await writeIamAuditEvent({
    action: {{constantCase jobName}}_WORKFLOW_AUDIT_ACTIONS.{{camelCase jobName}}Completed,
    actorUserId: payload.actorUserId,
    actorSessionId: payload.actorSessionId,
    organizationId: payload.organizationId,
    resourceType: "{{slug}}.{{auditObject}}",
    resourceId: payload.resourceId,
    metadata: {},
  })
}

async function {{camelCase jobName}}FailedStep(
  payload: {{pascalCase jobName}}Payload,
  err: unknown
) {
  "use step"

  const message = err instanceof Error ? err.message : "Workflow failed"

  await writeIamAuditEvent({
    action: {{constantCase jobName}}_WORKFLOW_AUDIT_ACTIONS.{{camelCase jobName}}Failed,
    actorUserId: payload.actorUserId,
    actorSessionId: payload.actorSessionId,
    organizationId: payload.organizationId,
    resourceType: "{{slug}}.{{auditObject}}",
    resourceId: payload.resourceId,
    metadata: { message },
  })
}
