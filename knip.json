{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "next": true,
  "vitest": true,
  "playwright": true,
  "treatConfigHintsAsErrors": true,
  "ignoreExportsUsedInFile": true,
  "entry": [
    "package.json",
    "scripts/**/*.{mjs,cjs,js,ts}",
    "tests/**/*.{ts,tsx}"
  ],
  "rules": {
    "files": "error",
    "dependencies": "error",
    "devDependencies": "error",
    "unlisted": "error",
    "unresolved": "error",
    "binaries": "error",
    "catalog": "error",
    "exports": "error",
    "types": "error",
    "enumMembers": "error",
    "namespaceMembers": "error",
    "nsExports": "error",
    "nsTypes": "error",
    "duplicates": "error"
  },
  "ignoreFiles": ["components/ui/**", "hooks/use-mobile.ts"],
  "ignoreDependencies": [
    "@base-ui/react",
    "@hookform/resolvers",
    "cmdk",
    "date-fns",
    "embla-carousel-react",
    "react-day-picker",
    "react-hook-form",
    "react-resizable-panels",
    "recharts",
    "vaul"
  ],
  "ignoreIssues": {
    "lib/auth/index.ts": [
      "exports",
      "types",
      "enumMembers",
      "namespaceMembers",
      "nsExports",
      "nsTypes"
    ],
    "lib/auth-client.ts": ["exports", "types"],
    "lib/design-system.ts": [
      "exports",
      "types",
      "enumMembers",
      "namespaceMembers",
      "nsExports",
      "nsTypes"
    ],
    "lib/features/*/index.ts": [
      "exports",
      "types",
      "enumMembers",
      "namespaceMembers",
      "nsExports",
      "nsTypes"
    ],
    "lib/features/**/constants.ts": ["exports", "types"],
    "lib/**/*.shared.ts": [
      "exports",
      "types",
      "enumMembers",
      "namespaceMembers"
    ],
    "lib/auth/**/*.server.ts": ["exports", "types"],
    "lib/auth/org-audit.server.ts": ["exports", "types"],
    "lib/dashboard-module-paths.ts": ["exports", "types"],
    "lib/dashboard-org-path.shared.ts": ["exports", "types"],
    "lib/site.ts": ["exports", "types", "duplicates"],
    "lib/tenant.ts": ["exports", "types", "duplicates"],
    "components/ui/**/*.tsx": [
      "exports",
      "types",
      "enumMembers",
      "namespaceMembers",
      "nsExports",
      "nsTypes"
    ],
    "components/ui/**/*.ts": ["exports", "types"],
    "components/afenda-brand.tsx": ["exports", "types"],
    "components/auth/**/*.tsx": ["exports", "types"],
    "components/dashboard/**/*.tsx": ["exports", "types"],
    "i18n/navigation.tsx": ["exports", "types"],
    "tests/fixtures/**/*.ts": ["exports", "types"],
    "lib/features/**/data/*.ts": ["exports", "types"],
    "lib/features/**/actions/*.ts": ["exports", "types"],
    "lib/features/**/schemas/*.ts": ["exports", "types"],
    "lib/features/**/components/*.tsx": ["exports", "types"],
    "lib/features/**/*.contract.ts": ["exports", "types"]
  }
}
