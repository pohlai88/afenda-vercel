# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing & CI tool output (Vitest coverage, Playwright junit/traces/screenshots, etc.)
/.artifacts/

# Ad-hoc CLI output files that must never be committed
knip-output.txt

# Local Playwright MCP / browser debug captures (not product source)
.playwright-mcp/

# next.js
/.next/
/out/
# SWC compiler cache (Next.js Turbopack/SWC runtime artefact — do not commit)
/.swc/

# Workflow DevKit — generated route bundles (`withWorkflow`); do not commit
/app/.well-known/workflow/

# production
/build

# misc
.DS_Store
.venv/

*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# env files (Next.js: .env.local is loaded for local dev; keep secrets out of git)
.env
.env*.local
# Maintainer copy for `pnpm env:sync` → .env.local; may hold secrets — never commit
.env.config
.env.vercel
.env.vercel.pull

# Vercel CLI (project link; may reference env)
.vercel

# local Cursor IDE preferences
.cursor/settings.json
# Cursor IDE debug traces (local agent/session debugging)
.cursor/debug*.log

# Brand guideline source export — exceeds GitHub 100 MB limit; keep locally or use Git LFS
public/afenda-brand/brand-guideline/afenda-figma-export-full-guideline.png

# typescript
*.tsbuildinfo
next-env.d.ts
